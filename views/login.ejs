<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Admin Login</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #a8edea 0%, #29b6d1 40%, #1e7aa8 70%, #c9d6f5 100%);
      font-family: 'Segoe UI', sans-serif;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    body::-webkit-scrollbar { display: none; }

    .card {
      background: #fff;
      border-radius: 16px;
      padding: 2rem 2.2rem;
      width: 100%;
      max-width: 420px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 15px;
    }

    h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; margin-bottom: 4px; }

    .subtitle { font-size: 13px; color: #7a8499; margin-bottom: 1.4rem; }

    label { display: block; font-size: 13px; font-weight: 600; color: #2d3748; margin-bottom: 6px; }

    input[type="email"],
    input[type="password"],
    input[type="text"] {
      width: 100%;
      border: 1.5px solid #cbd5e0;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 14px;
      color: #2d3748;
      outline: none;
      margin-bottom: 1rem;
      transition: border-color .2s;
    }

    input:focus { border-color: #1a8fc1; }

    .input-error { border-color: #e53e3e !important; }

    .error-msg { color: #e53e3e; font-size: 12px; margin-top: -10px; margin-bottom: 12px; }

    .password-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }

    .forgot { font-size: 13px; color: #1a8fc1; text-decoration: none; font-weight: 500; }

    .password-wrap {
      position: relative;
      margin-bottom: 1rem;
    }

    .password-wrap input {
      margin-bottom: 0;
      padding-right: 40px;
    }

    .toggle-pw {
      position: absolute;
      right: 12px;
      top: 0;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: none;
      border: none;
      cursor: pointer;
      color: #a0aec0;
      padding: 0;
      line-height: 1;
    }

    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 1.2rem;
    }

    .checkbox-row input { width: 16px; height: 16px; accent-color: #1a8fc1; cursor: pointer; margin-bottom: 0; }
    .checkbox-row label { margin-bottom: 0; font-weight: 400; color: #4a5568; cursor: pointer; }

    .btn-continue {
      width: 100%;
      background: #1a8fc1;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 12px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .3px;
      transition: background .2s;
    }

    .btn-continue:hover { background: #157aab; }

    .footer-text {
      text-align: center;
      font-size: 13px;
      color: #718096;
      margin-top: 1.2rem;
    }

    .footer-text a { color: #1a8fc1; text-decoration: none; font-weight: 600; }
  </style>
</head>
<body>

<div class="card">

  <!-- Brand -->
  <div class="brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>

  <h1>Admin Login</h1>
  <p class="subtitle">Welcome back. Enter your credentials to access your account</p>

  <!-- Show error from server if any -->
  <% if (typeof error !== 'undefined' && error) { %>
    <p class="error-msg"><%= error %></p>
  <% } %>

  <form action="/login" method="POST">

    <label for="email">Email Address</label>
    <input type="email" id="email" name="email" placeholder="hello@example.com" required />

    <div class="password-row">
      <label for="password">Password</label>
      <a href="/forgot-password" class="forgot">Forgot Password</a>
    </div>

    <div class="password-wrap">
      <input type="password" id="password" name="password"
             class="<%= typeof error !== 'undefined' && error ? 'input-error' : '' %>"
             placeholder="••••••••" required />
      <button type="button" class="toggle-pw" onclick="togglePassword()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2">
          <ellipse cx="12" cy="12" rx="10" ry="6"/>
          <circle cx="12" cy="12" r="2.5"/>
        </svg>
      </button>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <p class="error-msg">Please enter correct password</p>
    <% } %>

    <div class="checkbox-row">
      <input type="checkbox" id="remember" name="remember" checked />
      <label for="remember">Keep me signed in</label>
    </div>

    <button type="submit" class="btn-continue">Continue</button>

  </form>

  <p class="footer-text">
    Don't have an Account?
    <a href="/contact-admin">Contact admin here</a>
  </p>

</div>

<script>
  function togglePassword() {
    const pw = document.getElementById('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
  }
</script>

</body>
</html>