/* ── Shared glass theme (aligned with login; no droplets) ── */
/* Panels use stronger frost so dark text stays readable on the gradient. */

  body {
    background: radial-gradient(ellipse 120% 85% at 50% -15%, rgba(255, 255, 255, 0.11) 0%, transparent 48%),
      radial-gradient(ellipse 70% 45% at 85% 100%, rgba(42, 157, 143, 0.22) 0%, transparent 42%),
      linear-gradient(165deg, #0a4d68 0%, #0d7b9c 28%, #2a9d8f 55%, #1a5f7a 85%, #053b50 100%);
    background-attachment: fixed;
    color: #142434;
  }

  /* Shell */
  .sidebar {
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(22px) saturate(165%);
    -webkit-backdrop-filter: blur(22px) saturate(165%);
    border-right-color: rgba(255, 255, 255, 0.28);
    box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.08);
  }

  .sidebar-brand {
    color: rgba(245, 252, 255, 0.98);
    border-bottom-color: rgba(255, 255, 255, 0.22);
    text-shadow: 0 1px 2px rgba(0, 40, 60, 0.35);
  }

  .sidebar-brand svg path,
  .sidebar-brand svg polygon {
    fill: rgba(245, 252, 255, 0.96);
  }

  .nav-item {
    color: rgba(238, 248, 252, 0.92);
    border-radius: 0;
    text-shadow: 0 1px 2px rgba(0, 30, 50, 0.25);
  }

  .nav-item:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
    text-shadow: none;
  }

  .nav-item.active {
    background: rgba(255, 255, 255, 0.26);
    color: #ffffff;
    font-weight: 600;
    text-shadow: none;
  }

  .sidebar-bottom {
    border-top-color: rgba(255, 255, 255, 0.2);
  }

  .topbar {
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    border-bottom-color: rgba(255, 255, 255, 0.26);
  }

  .topbar-icon {
    background: rgba(255, 255, 255, 0.34);
    border: 1px solid rgba(255, 255, 255, 0.42);
    color: #124252;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .topbar-icon:hover {
    background: rgba(255, 255, 255, 0.52);
    color: #053b50;
  }

  /* Page chrome on the open gradient only (not inside cards/tables) */
  .content > .greeting,
  .header-row > .page-title,
  .header-row > .title,
  .page-header .page-title,
  .page-header .device-name,
  .page-header .live-badge {
    color: rgba(255, 255, 255, 0.98);
    text-shadow: 0 1px 3px rgba(0, 35, 55, 0.45);
  }

  .greeting span {
    color: rgba(232, 246, 252, 0.9);
    text-shadow: 0 1px 2px rgba(0, 35, 55, 0.35);
  }

  .page-header .page-subtitle,
  .header-row .page-subtitle {
    color: rgba(232, 245, 252, 0.9);
    text-shadow: 0 1px 2px rgba(0, 35, 55, 0.35);
  }

  .header-links a:hover,
  .date-label:hover {
    color: #ffffff;
  }

  .header-links a,
  .date-label {
    color: rgba(220, 245, 255, 0.95);
    text-shadow: 0 1px 2px rgba(0, 35, 55, 0.35);
  }

  .daily-btn {
    color: #184a5c;
    text-shadow: none;
  }

  .daily-btn:hover {
    color: #053b50;
  }

  /* Frosted panels — higher opacity for contrast */
  .topbar-popover,
  .devices-popover,
  .filter-panel,
  .action-menu,
  .device-menu,
  .daily-menu,
  .table-wrap,
  .metric-card,
  .chart-card,
  .chart-card-full,
  .potability-card,
  .status-card,
  .parameter-card,
  .stat-card,
  .card,
  .time-data-card,
  .search-box,
  .filter-btn,
  .time-data-item {
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-color: rgba(255, 255, 255, 0.55);
    box-shadow:
      0 8px 32px rgba(0, 30, 50, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    color: #142434;
  }

  .table-wrap tbody td,
  .table-wrap thead th,
  .metric-card,
  .chart-card,
  .chart-card-full,
  .potability-card,
  .status-card,
  .parameter-card,
  .stat-card,
  .card,
  .time-data-card {
    color: #142434;
  }

  .chart-title,
  .potability-title,
  .potability-status,
  .metric-label,
  .metric-value,
  .metric-unit,
  .status-label,
  .status-value,
  .parameter-threshold,
  .parameter-status {
    color: inherit;
  }

  .metric-label,
  .status-label,
  .stat-label {
    color: #5c6b7a;
  }

  .metric-value,
  .stat-value,
  .parameter-status,
  .potability-status,
  .chart-title,
  .potability-title {
    color: #0f2942;
  }

  thead th {
    color: #5c6b7a !important;
    border-bottom-color: rgba(15, 50, 70, 0.12);
  }

  tbody td {
    color: #1f3347 !important;
    border-bottom-color: rgba(15, 50, 70, 0.08);
  }

  .popover-item,
  .device-item {
    background: rgba(255, 255, 255, 0.4);
    border-color: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #142434;
  }

  .popover-item strong,
  .popover-item span,
  .device-item strong,
  .device-item span {
    color: inherit;
  }

  .popover-item span,
  .device-item span {
    color: #4a6578;
  }

  .device-item-btn:hover .device-item {
    background: rgba(255, 255, 255, 0.62);
    border-color: rgba(26, 143, 193, 0.45);
  }

  .popover-title {
    color: #0f2942 !important;
  }

  .avatar-head {
    border-bottom-color: rgba(15, 50, 70, 0.12);
  }

  .avatar-meta strong {
    color: #0f2942;
  }

  .avatar-meta span {
    color: #4a6578;
  }

  .search-box input,
  .filter-select,
  .field input,
  .field select,
  .snapshot-controls input {
    color: #142434 !important;
  }

  .search-box input::placeholder {
    color: rgba(31, 51, 71, 0.45);
  }

  .toolbar {
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.5);
    color: #142434;
  }

  .tool-btn {
    background: rgba(255, 255, 255, 0.65);
    border-color: rgba(255, 255, 255, 0.55);
    color: #1a3748;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .tool-btn:hover {
    background: rgba(255, 255, 255, 0.88);
    border-color: rgba(26, 143, 193, 0.5);
    color: #053b50;
  }

  .btn:not(.primary) {
    background: rgba(255, 255, 255, 0.55);
    border-color: rgba(255, 255, 255, 0.5);
    color: #1a3748;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .btn.primary {
    border-color: rgba(255, 255, 255, 0.35);
    color: #ffffff !important;
    background: linear-gradient(135deg, rgba(13, 123, 156, 0.98), rgba(10, 77, 104, 0.99));
    box-shadow: 0 4px 18px rgba(5, 50, 70, 0.4);
  }

  .field label,
  .helper {
    color: #4a6578;
  }

  .editor {
    background: rgba(255, 255, 255, 0.6);
    border-color: rgba(255, 255, 255, 0.5);
    color: #142434 !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .editor.drop-target {
    background: rgba(220, 248, 255, 0.75);
    border-color: rgba(26, 143, 193, 0.65);
  }

  .data-pill {
    background: rgba(236, 252, 255, 0.75);
    border-color: rgba(26, 143, 193, 0.35);
    color: #0d4a61;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  /* Period pills live inside frosted chart cards → dark text */
  .period-btn:not(.active) {
    background: rgba(255, 255, 255, 0.45);
    border-color: rgba(15, 50, 70, 0.15);
    color: #395a6c;
  }

  .period-btn:not(.active):hover {
    border-color: rgba(26, 143, 193, 0.65);
    color: #065a73;
    background: rgba(255, 255, 255, 0.72);
  }

  .period-btn.active {
    background: rgba(15, 50, 70, 0.88);
    border-color: rgba(15, 50, 70, 0.5);
    color: #f0fdfc !important;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 10px rgba(0, 30, 50, 0.2);
  }

  .daily-menu a:hover {
    background: rgba(255, 255, 255, 0.55);
    color: #053b50;
  }

  .daily-menu a {
    color: #1f3347;
  }

  .action-item {
    background: rgba(255, 255, 255, 0.35);
    color: #1f3347;
  }

  .action-item:hover {
    background: rgba(232, 250, 255, 0.85);
    color: #065a73;
  }

  .panel-title {
    color: #0f2942 !important;
  }

  .device-option {
    background: rgba(255, 255, 255, 0.3);
    color: #1f3347;
  }

  .device-option:hover {
    background: rgba(232, 250, 255, 0.75);
    color: #065a73;
  }

  .filter-title {
    color: #5c6b7a !important;
  }

  .filter-group label {
    color: #4a6578 !important;
  }

  .time-data-title,
  .time-data-item span {
    color: #0f2942 !important;
  }

  .time-data-item strong,
  .time-data-sub {
    color: #5c6b7a !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .sidebar,
    .topbar,
    .metric-card,
    .chart-card,
    .stat-card {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }
