</div>
<div class="time-data-modal" id="timeDataModal">
  <div class="time-data-card">
    <div class="time-data-head">
      <div class="time-data-title">Event Snapshot</div>
      <button type="button" class="time-data-close" id="timeDataClose">×</button>
    </div>
    <div class="time-data-sub" id="timeDataSub"></div>
    <div class="time-data-grid" id="timeDataGrid"></div>
  </div>
</div>
<script>
  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) closeAllPopovers();
  });

  const tbody = document.getElementById('historyTableBody');
  const timeDataModal = document.getElementById('timeDataModal');
  const timeDataSub = document.getElementById('timeDataSub');
  const timeDataGrid = document.getElementById('timeDataGrid');
  const timeDataClose = document.getElementById('timeDataClose');
  const searchInput = document.getElementById('historySearchInput');
  const filterToggleBtn = document.getElementById('filterToggleBtn');
  const filterPanel = document.getElementById('historyFilterPanel');
  const eventTypeFilter = document.getElementById('eventTypeFilter');
  const valueFilter = document.getElementById('valueFilter');
  const dateOrderFilter = document.getElementById('dateOrderFilter');
  const clearHistoryFilters = document.getElementById('clearHistoryFilters');

  function closeAllRowMenus() {
    document.querySelectorAll('.action-menu').forEach((menu) => menu.classList.remove('show'));
  }

  if (tbody) {
    tbody.addEventListener('click', (event) => {
      const actionBtn = event.target.closest('[data-row-action]');
      if (actionBtn) {
        event.stopPropagation();
        const menu = actionBtn.parentElement.querySelector('.action-menu');
        const isOpen = menu && menu.classList.contains('show');
        closeAllRowMenus();
        if (menu && !isOpen) {
          menu.classList.remove('open-up');
          const btnRect = actionBtn.getBoundingClientRect();
          const spaceBelow = window.innerHeight - btnRect.bottom;
          if (spaceBelow < 150) menu.classList.add('open-up');
          menu.classList.add('show');
        }
        return;
      }

      const actionItem = event.target.closest('.action-item');
      if (!actionItem) return;
      const row = actionItem.closest('tr');
      if (!row) return;
      const action = actionItem.getAttribute('data-action');
      const timestamp = row.children[0].textContent.trim();
      const eventType = row.children[1].textContent.trim();
      const description = row.children[2].textContent.trim();
      const value = row.children[3].textContent.trim() || 'N/A';

      if (action === 'delete') {
        row.remove();
      } else if (action === 'pdf') {
        window.print();
      } else if (action === 'time-data') {
        if (timeDataSub) timeDataSub.textContent = `${eventType} - ${timestamp}`;
        if (timeDataGrid) {
          timeDataGrid.innerHTML = `
            <div class="time-data-item"><strong>Timestamp</strong><span>${timestamp}</span></div>
            <div class="time-data-item"><strong>Event Type</strong><span>${eventType}</span></div>
            <div class="time-data-item"><strong>Description</strong><span>${description}</span></div>
            <div class="time-data-item"><strong>Value</strong><span>${value}</span></div>
          `;
        }
        if (timeDataModal) timeDataModal.classList.add('show');
      }
      closeAllRowMenus();
    });
  }

  function parseTimestamp(text) {
    return new Date(text.replace(',', '')).getTime();
  }

  function applyHistoryFilters() {
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    const term = (searchInput?.value || '').toLowerCase().trim();
    const eventType = eventTypeFilter?.value || 'all';
    const valueMode = valueFilter?.value || 'all';
    const dateMode = dateOrderFilter?.value || 'newest';

    rows.forEach((row) => {
      const timestamp = row.children[0].textContent.trim();
      const type = row.children[1].textContent.trim();
      const desc = row.children[2].textContent.trim();
      const value = row.children[3].textContent.trim();
      const haystack = `${timestamp} ${type} ${desc} ${value}`.toLowerCase();

      const searchOk = !term || haystack.includes(term);
      const typeOk = eventType === 'all' || type === eventType;
      const valueOk = valueMode === 'all' || (valueMode === 'has' ? value !== '' : value === '');
      row.style.display = searchOk && typeOk && valueOk ? '' : 'none';
    });

    rows
      .sort((a, b) => {
        const aDate = parseTimestamp(a.children[0].textContent.trim());
        const bDate = parseTimestamp(b.children[0].textContent.trim());
        return dateMode === 'oldest' ? aDate - bDate : bDate - aDate;
      })
      .forEach((row) => tbody.appendChild(row));
  }

  if (searchInput) searchInput.addEventListener('input', applyHistoryFilters);
  [eventTypeFilter, valueFilter, dateOrderFilter].forEach((el) => {
    if (el) el.addEventListener('change', applyHistoryFilters);
  });

  if (clearHistoryFilters) {
    clearHistoryFilters.addEventListener('click', () => {
      if (eventTypeFilter) eventTypeFilter.value = 'all';
      if (valueFilter) valueFilter.value = 'all';
      if (dateOrderFilter) dateOrderFilter.value = 'newest';
      if (searchInput) searchInput.value = '';
      applyHistoryFilters();
    });
  }

  if (filterToggleBtn && filterPanel) {
    filterToggleBtn.addEventListener('click', (event) => {
      event.stopPropagation();
      filterPanel.classList.toggle('show');
    });
    filterPanel.addEventListener('click', (event) => event.stopPropagation());
  }

  document.addEventListener('click', () => closeAllRowMenus());
  document.addEventListener('click', (event) => {
    if (filterPanel && !event.target.closest('.filter-wrap')) filterPanel.classList.remove('show');
  });
  if (timeDataClose) timeDataClose.addEventListener('click', () => timeDataModal && timeDataModal.classList.remove('show'));
  if (timeDataModal) {
    timeDataModal.addEventListener('click', (event) => {
      if (event.target === timeDataModal) timeDataModal.classList.remove('show');
    });
  }
  applyHistoryFilters();
</script>
</body>
</html>
