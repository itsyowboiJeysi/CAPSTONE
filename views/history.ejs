      <div>
        <h1 class="page-title">History</h1>
        <p class="page-subtitle">Sensor Data Records and Monitoring History</p>
      </div>
      <div class="header-actions">
        <div class="search-box">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9aa3af" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Search" id="historySearchInput" />
        </div>
        <div class="filter-wrap">
          <button class="filter-btn" type="button" id="filterToggleBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="7" y1="12" x2="17" y2="12"/><line x1="10" y1="18" x2="14" y2="18"/></svg>
            Filters
          </button>
          <div class="filter-panel" id="historyFilterPanel">
            <div class="filter-title">FILTER LOGS</div>
            <div class="filter-group">
              <label for="eventTypeFilter">Event type</label>
              <select class="filter-select" id="eventTypeFilter">
                <option value="all">All</option>
