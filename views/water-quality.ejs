<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Water Quality</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    body::-webkit-scrollbar { display: none; }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }
    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      cursor: pointer;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
    .sidebar-bottom { padding: 1rem 0; border-top: 1px solid #f0f4f8; }

    /* ── MAIN ── */
    .main { margin-left: 210px; flex: 1; display: flex; flex-direction: column; }

    /* ── TOPBAR ── */
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      cursor: pointer;
      color: #6b7280;
    }
    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }
    .topbar-action { position: relative; }
    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }
    .topbar-popover.show { display: block; }
    .popover-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .65rem;
    }
    .popover-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .45rem;
    }
    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .popover-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .popover-item span {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.35;
      display: block;
    }
    .avatar-panel { width: 250px; }
    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }
    .avatar-chip {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }
    .avatar-meta strong {
      display: block;
      font-size: 13px;
      color: #1a1a2e;
    }
    .avatar-meta span {
      font-size: 12px;
      color: #6b7280;
    }
    .avatar-actions {
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }
    .avatar-actions a {
      text-decoration: none;
      font-size: 12px;
      color: #1a8fc1;
      font-weight: 600;
      padding: 4px 2px;
    }
    .avatar-actions a:hover { color: #157aab; }
    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
    }
    .badge-blue { background: #1a8fc1; }
    .badge-indigo { background: #5b5fcf; }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
      cursor: pointer;
    }

    /* ── CONTENT ── */
    .content { padding: 1.6rem 2rem; flex: 1; }

    .page-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      margin-bottom: 1.4rem;
    }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a2e; }
    .device-name {
      font-size: 28px;
      font-weight: 800;
      color: #1a1a2e;
      text-align: center;
      letter-spacing: 1px;
    }
    .header-right {
      display: flex;
      justify-content: flex-end;
    }
    .header-links a {
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      font-weight: 500;
    }
    .header-links a:hover { color: #1a8fc1; }
    .header-links-popover-wrap {
      position: relative;
      display: inline-flex;
    }
    .devices-popover {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      width: 250px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 10px;
      box-shadow: 0 12px 24px rgba(26, 35, 56, 0.12);
      padding: .7rem;
      display: none;
      z-index: 70;
    }
    .devices-popover.show { display: block; }
    .device-item-btn {
      width: 100%;
      text-align: left;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }
    .device-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .5rem .6rem;
      background: #f9fbfd;
      margin-bottom: .45rem;
    }
    .device-item:last-child { margin-bottom: 0; }
    .device-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .device-item span {
      display: block;
      font-size: 12px;
      color: #6b7280;
    }
    .device-item-btn:hover .device-item { border-color: #1a8fc1; background: #eef7fc; }

    /* Metric cards */
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.4rem;
    }
    .metric-card {
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      padding: 1rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .metric-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .metric-label { font-size: 12px; color: #9aa3af; margin-bottom: 8px; }
    .metric-value { font-size: 26px; font-weight: 700; color: #1a1a2e; line-height: 1; }
    .metric-unit { font-size: 13px; font-weight: 400; color: #6b7280; margin-left: 2px; }

    /* Middle row: chart only */
    .middle-row {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .chart-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.2rem 1.4rem;
    }
    .chart-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .chart-title { font-size: 15px; font-weight: 700; color: #1a1a2e; margin-right: auto; }
    .period-btn {
      background: none;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 4px 12px;
      font-size: 12px;
      color: #6b7280;
      cursor: pointer;
      transition: all .15s;
    }
    .period-btn.active {
      background: #fff;
      border-color: #1a1a2e;
      color: #1a1a2e;
      font-weight: 600;
    }
    .period-btn:hover:not(.active) { border-color: #1a8fc1; color: #1a8fc1; }
    .chart-wrap { position: relative; height: 220px; }

    /* Parameter status metric grid */
    .parameter-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.4rem;
    }
    .parameter-card {
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      padding: 1rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .parameter-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .parameter-status {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 20px;
      font-weight: 700;
      color: #1a1a2e;
      line-height: 1.15;
      margin-bottom: 8px;
    }
    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      flex-shrink: 0;
      background: #9aa3af;
    }
    .state-normal .status-dot { background: #38a169; }
    .state-warning .status-dot { background: #d69e2e; }
    .state-unsafe .status-dot { background: #e53e3e; }
    .parameter-threshold {
      font-size: 12px;
      color: #6b7280;
    }

    /* Bottom status cards */
    .status-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    .status-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 12px;
      padding: 1rem 1.4rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .status-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .status-label { font-size: 12px; color: #9aa3af; margin-bottom: 8px; }
    .status-value { font-size: 20px; font-weight: 700; color: #1a1a2e; }
  </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/monitoring" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Real-Time Monitoring
    </a>
    <a href="/water-quality" class="nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6 9 4 13 4 16a8 8 0 0016 0c0-3-2-7-8-14z"/></svg>
      Water Quality
    </a>
    <a href="/consumption" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Consumption
    </a>
    <a href="/alerts" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Alerts
    </a>
    <a href="/history" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/><rect x="2" y="3" width="4" height="4" rx="1"/><rect x="2" y="10" width="4" height="4" rx="1"/><rect x="2" y="17" width="4" height="4" rx="1"/></svg>
      History/Logs
    </a>
    <a href="/reports" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>
      Reports
    </a>
 
</aside>

<!-- MAIN -->
<div class="main">
  <header class="topbar">
  
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge badge-indigo">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item">
            <strong>pH Warning</strong>
            <span>Reservoir 2 recorded pH 6.4 at 08:45 AM.</span>
          </li>
          <li class="popover-item">
            <strong>Flow Update</strong>
            <span>Main line flow increased by 12% this hour.</span>
          </li>
          <li class="popover-item">
            <strong>Reminder</strong>
            <span>Monthly compliance report is due today.</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta">
            <strong>Admin User</strong>
            <span>admin@etubig.local</span>
          </div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header">
      <div class="page-title">Water Quality</div>
      <div class="device-name" id="deviceName">ESP DEVICE NAME</div>
      <div class="header-right">
        <div class="header-links">
          <div class="header-links-popover-wrap" data-device-wrap>
            <a href="#" id="devicesLink">Devices</a>
            <div class="devices-popover" id="devicesPopover"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Metrics -->
    <div class="metric-grid">
      <div class="metric-card">
        <div class="metric-label">pH Level</div>
        <div class="metric-value" data-metric-value="ph">7.2<span class="metric-unit">pH</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Turbidity</div>
        <div class="metric-value" data-metric-value="turbidity">2.1<span class="metric-unit">NTU</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Temperature</div>
        <div class="metric-value" data-metric-value="temperature">23<span class="metric-unit">°C</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Flow Rate</div>
        <div class="metric-value" data-metric-value="flow">50<span class="metric-unit">L/min</span></div>
      </div>
    </div>

    <!-- Chart -->
    <div class="middle-row">
      <div class="chart-card">
        <div class="chart-header">
          <span class="chart-title">Water Quality Reports</span>
          <button class="period-btn active" onclick="switchPeriod(this,'30m')">30 mins</button>
          <button class="period-btn" onclick="switchPeriod(this,'6m')">6 Months</button>
          <button class="period-btn" onclick="switchPeriod(this,'30d')">30 Days</button>
          <button class="period-btn" onclick="switchPeriod(this,'7d')">7 Days</button>
        </div>
        <div class="chart-wrap">
          <canvas id="qualityChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Status by Parameters -->
    <div class="parameter-grid">
      <div class="parameter-card" data-param-card="ph">
        <div class="metric-label">pH Status</div>
        <div class="parameter-status"><span class="status-dot"></span><span data-param-text="ph">Normal</span></div>
        <div class="parameter-threshold">Normal range: 6.8 - 8.2 pH</div>
      </div>
      <div class="parameter-card" data-param-card="turbidity">
        <div class="metric-label">Turbidity Status</div>
        <div class="parameter-status"><span class="status-dot"></span><span data-param-text="turbidity">Normal</span></div>
        <div class="parameter-threshold">Normal range: <= 1.0 NTU</div>
      </div>
      <div class="parameter-card" data-param-card="temperature">
        <div class="metric-label">Temperature Status</div>
        <div class="parameter-status"><span class="status-dot"></span><span data-param-text="temperature">Normal</span></div>
        <div class="parameter-threshold">Normal range: 20 - 28 C</div>
      </div>
      <div class="parameter-card" data-param-card="flow">
        <div class="metric-label">Flow Rate Status</div>
        <div class="parameter-status"><span class="status-dot"></span><span data-param-text="flow">Normal</span></div>
        <div class="parameter-threshold">Normal range: 40 - 65 L/min</div>
      </div>
    </div>

    <!-- Bottom status cards -->
    <div class="status-grid">
      <div class="status-card">
        <div class="status-label">Combine Status</div>
        <div class="status-value" id="combinedStatus">Normal</div>
      </div>
      <div class="status-card">
        <div class="status-label">Last Update</div>
        <div class="status-value" id="lastUpdate">--</div>
      </div>
    </div>
  </div>
</div>

<script>
  // Clock
  function updateClock() {
    const now = new Date();
    document.getElementById('lastUpdate').textContent =
      now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Chart
  const months12 = ['Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan'];
  const days7    = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  const periodData = {
    '30m': {
      labels: Array.from({length:30}, (_,i) => i%5===0 ? `${i}m` : ''),
      datasets: [
        Array.from({length:30}, (_,i) => 300 + Math.sin(i*0.3)*80 + Math.random()*20),
        Array.from({length:30}, (_,i) => 190 + Math.sin(i*0.4)*50 + Math.random()*15),
        Array.from({length:30}, (_,i) => 110 + Math.sin(i*0.5)*30 + Math.random()*10),
      ]
    },
    '6m': {
      labels: ['Aug','Sep','Oct','Nov','Dec','Jan'],
      datasets: [
        [430,480,520,490,560,610],
        [280,320,350,330,370,410],
        [160,180,200,185,210,230],
      ]
    },
    '30d': {
      labels: Array.from({length:30}, (_,i) => i%5===0 ? `D${i+1}` : ''),
      datasets: [
        Array.from({length:30}, () => Math.floor(350+Math.random()*200)),
        Array.from({length:30}, () => Math.floor(200+Math.random()*100)),
        Array.from({length:30}, () => Math.floor(100+Math.random()*60)),
      ]
    },
    '7d': {
      labels: days7,
      datasets: [
        [490,510,525,480,560,545,610],
        [330,345,360,320,380,365,410],
        [185,195,205,175,215,200,230],
      ]
    },
  };
  const deviceProfiles = [
    { name: 'ESP-32 Main Tank', topic: 'etubig/main-tank/status', periodData },
    {
      name: 'ESP-32 Zone B',
      topic: 'etubig/zone-b/status',
      periodData: {
        '30m': {
          labels: Array.from({length:30}, (_,i) => i%5===0 ? `${i}m` : ''),
          datasets: [
            Array.from({length:30}, (_,i) => 270 + Math.sin(i*0.28)*75 + Math.random()*18),
            Array.from({length:30}, (_,i) => 240 + Math.sin(i*0.35)*55 + Math.random()*20),
            Array.from({length:30}, (_,i) => 140 + Math.sin(i*0.48)*34 + Math.random()*10),
          ]
        },
        '6m': { labels: ['Aug','Sep','Oct','Nov','Dec','Jan'], datasets: [[400,450,495,470,530,575],[300,340,360,350,390,430],[175,190,210,195,220,245]] },
        '30d': { labels: Array.from({length:30}, (_,i) => i%5===0 ? `D${i+1}` : ''), datasets: [Array.from({length:30}, () => Math.floor(320+Math.random()*180)),Array.from({length:30}, () => Math.floor(220+Math.random()*120)),Array.from({length:30}, () => Math.floor(120+Math.random()*75))] },
        '7d': { labels: days7, datasets: [[460,480,505,470,530,520,575],[345,350,370,335,395,380,430],[200,205,212,188,225,215,245]] },
      }
    },
    {
      name: 'ESP-8266 Intake',
      topic: 'etubig/intake/status',
      periodData: {
        '30m': {
          labels: Array.from({length:30}, (_,i) => i%5===0 ? `${i}m` : ''),
          datasets: [
            Array.from({length:30}, (_,i) => 350 + Math.sin(i*0.22)*65 + Math.random()*14),
            Array.from({length:30}, (_,i) => 140 + Math.sin(i*0.40)*32 + Math.random()*12),
            Array.from({length:30}, (_,i) => 95 + Math.sin(i*0.56)*25 + Math.random()*8),
          ]
        },
        '6m': { labels: ['Aug','Sep','Oct','Nov','Dec','Jan'], datasets: [[470,500,540,515,565,605],[210,230,245,225,255,280],[140,155,168,150,172,190]] },
        '30d': { labels: Array.from({length:30}, (_,i) => i%5===0 ? `D${i+1}` : ''), datasets: [Array.from({length:30}, () => Math.floor(380+Math.random()*170)),Array.from({length:30}, () => Math.floor(140+Math.random()*85)),Array.from({length:30}, () => Math.floor(85+Math.random()*55))] },
        '7d': { labels: days7, datasets: [[520,530,550,525,580,570,605],[225,235,248,220,260,250,280],[165,168,176,160,182,175,190]] },
      }
    },
  ];

  const colorSet = [
    { line: '#2d3ac8', fill: 'rgba(45,58,200,0.12)' },
    { line: '#6b8cff', fill: 'rgba(107,140,255,0.09)' },
    { line: '#a5b4fc', fill: 'rgba(165,180,252,0.07)' },
  ];

  function makeDatasets(d) {
    return d.datasets.map((data, i) => ({
      data,
      borderColor: colorSet[i].line,
      backgroundColor: colorSet[i].fill,
      fill: true,
      tension: 0.5,
      borderWidth: i === 0 ? 2.5 : 1.5,
      pointRadius: 0,
    }));
  }

  const ctx = document.getElementById('qualityChart').getContext('2d');
  const deviceNameEl = document.getElementById('deviceName');
  let activeDevice = deviceProfiles[0];
  let currentPeriod = '30m';
  const qualityChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: activeDevice.periodData['30m'].labels,
      datasets: makeDatasets(activeDevice.periodData['30m']),
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 400 },
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9aa3af', font: { size: 11 } } },
        y: {
          display: true,
          beginAtZero: true,
          grid: { color: '#eef2f7' },
          ticks: {
            color: '#9aa3af',
            font: { size: 11 },
            precision: 0
          }
        },
      },
    }
  });

  function switchPeriod(btn, key) {
    btn.closest('.chart-header').querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentPeriod = key;
    const d = activeDevice.periodData[key];
    qualityChart.data.labels = d.labels;
    qualityChart.data.datasets = makeDatasets(d);
    qualityChart.update();
    syncMetricCardsFromChart();
  }

  // Keep top metric cards synced to chart's latest points
  function setMetricValue(key, value, unit) {
    const el = document.querySelector(`[data-metric-value="${key}"]`);
    if (!el || !Number.isFinite(value)) return;
    const rounded = key === 'temperature' || key === 'flow' ? Math.round(value) : value.toFixed(1);
    el.innerHTML = `${rounded}<span class="metric-unit">${unit}</span>`;
  }

  function syncMetricCardsFromChart() {
    const ds = qualityChart.data.datasets;
    if (!ds || ds.length < 3) return;

    const ph = ds[0].data[ds[0].data.length - 1];
    const turbidity = ds[1].data[ds[1].data.length - 1];
    const temperature = ds[2].data[ds[2].data.length - 1];
    const flow = 35 + (turbidity * 0.7);

    setMetricValue('ph', ph / 80 + 3, 'pH');
    setMetricValue('turbidity', turbidity / 90, 'NTU');
    setMetricValue('temperature', temperature / 6, '°C');
    setMetricValue('flow', flow, 'L/min');

    updateParameterStatus();
  }

  // Auto status by parameter based on metric values
  function getMetricNumber(key) {
    const el = document.querySelector(`[data-metric-value="${key}"]`);
    return el ? parseFloat(el.textContent) : NaN;
  }

  function classifyStatus(key, value) {
    if (Number.isNaN(value)) return 'warning';

    if (key === 'ph') {
      if (value < 6.5 || value > 8.5) return 'unsafe';
      if (value < 6.8 || value > 8.2) return 'warning';
      return 'normal';
    }

    if (key === 'turbidity') {
      if (value > 5) return 'unsafe';
      if (value > 1) return 'warning';
      return 'normal';
    }

    if (key === 'temperature') {
      if (value < 18 || value > 30) return 'unsafe';
      if (value < 20 || value > 28) return 'warning';
      return 'normal';
    }

    if (key === 'flow') {
      if (value < 30 || value > 75) return 'unsafe';
      if (value < 40 || value > 65) return 'warning';
      return 'normal';
    }

    return 'warning';
  }

  function labelFromState(state) {
    if (state === 'unsafe') return 'Unsafe';
    if (state === 'warning') return 'Warning';
    return 'Normal';
  }

  function updateParameterStatus() {
    const keys = ['ph', 'turbidity', 'temperature', 'flow'];
    let overall = 'normal';
    const severity = { normal: 0, warning: 1, unsafe: 2 };

    keys.forEach((key) => {
      const value = getMetricNumber(key);
      const state = classifyStatus(key, value);
      const card = document.querySelector(`[data-param-card="${key}"]`);
      const text = document.querySelector(`[data-param-text="${key}"]`);

      if (card) {
        card.classList.remove('state-normal', 'state-warning', 'state-unsafe');
        card.classList.add(`state-${state}`);
      }
      if (text) text.textContent = labelFromState(state);

      if (severity[state] > severity[overall]) overall = state;
    });

    const combinedStatus = document.getElementById('combinedStatus');
    if (combinedStatus) combinedStatus.textContent = labelFromState(overall);
  }

  syncMetricCardsFromChart();
  updateParameterStatus();
  setInterval(updateParameterStatus, 3000);

  // Topbar popovers (messages, notification + admin profile)
  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');
  const devicesLink = document.getElementById('devicesLink');
  const devicesPopover = document.getElementById('devicesPopover');
  const activeEspDevices = deviceProfiles;

  if (devicesPopover) {
    devicesPopover.innerHTML = activeEspDevices
      .map((device, index) => `<button type="button" class="device-item-btn" data-device-index="${index}"><div class="device-item"><strong>${device.name}</strong><span>MQTT: ${device.topic}</span></div></button>`)
      .join('');
  }

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  if (devicesLink && devicesPopover) {
    devicesLink.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      const isOpen = devicesPopover.classList.contains('show');
      closeAllPopovers();
      devicesPopover.classList.toggle('show', !isOpen);
    });

    devicesPopover.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-device-index]');
      if (!btn) return;
      const idx = Number(btn.getAttribute('data-device-index'));
      if (Number.isNaN(idx) || !activeEspDevices[idx]) return;
      activeDevice = activeEspDevices[idx];
      if (deviceNameEl) deviceNameEl.textContent = activeDevice.name;
      const d = activeDevice.periodData[currentPeriod] || activeDevice.periodData['30m'];
      qualityChart.data.labels = d.labels;
      qualityChart.data.datasets = makeDatasets(d);
      qualityChart.update();
      syncMetricCardsFromChart();
      devicesPopover.classList.remove('show');
    });
  }

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) {
      closeAllPopovers();
    }
    if (!event.target.closest('[data-device-wrap]')) {
      devicesPopover && devicesPopover.classList.remove('show');
    }
  });

  if (deviceNameEl) deviceNameEl.textContent = activeDevice.name;
</script>
</body>
</html>
