<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Consumption</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    .main::-webkit-scrollbar,
    .content::-webkit-scrollbar { display: none; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }
    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      cursor: pointer;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
    .sidebar-bottom {
      padding: 1rem 0;
      border-top: 1px solid #f0f4f8;
    }

    /* ── MAIN / TOPBAR ── */
    .main {
      margin-left: 210px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      cursor: pointer;
      color: #6b7280;
    }
    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }
    .topbar-action { position: relative; }
    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }
    .topbar-popover.show { display: block; }
    .popover-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .65rem;
    }
    .popover-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .45rem;
    }
    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .popover-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .popover-item span {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.35;
      display: block;
    }
    .avatar-panel { width: 250px; }
    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }
    .avatar-chip {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }
    .avatar-meta strong {
      display: block;
      font-size: 13px;
      color: #1a1a2e;
    }
    .avatar-meta span {
      font-size: 12px;
      color: #6b7280;
    }
    .avatar-actions {
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }
    .avatar-actions a {
      text-decoration: none;
      font-size: 12px;
      color: #1a8fc1;
      font-weight: 600;
      padding: 4px 2px;
    }
    .avatar-actions a:hover { color: #157aab; }
    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
    }
    .badge-indigo { background: #5b5fcf; }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
      cursor: pointer;
    }
    .content {
      padding: 1.6rem 2rem;
      flex: 1;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* ── PAGE-SPECIFIC STYLES ── */

    .page-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      margin-bottom: 1.6rem;
    }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a2e; }
    .device-name {
      font-size: 28px;
      font-weight: 800;
      color: #1a1a2e;
      text-align: center;
      letter-spacing: 1px;
    }
    .header-right {
      display: flex;
      justify-content: flex-end;
    }
    .header-links a {
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      font-weight: 500;
    }
    .header-links a:hover { color: #1a8fc1; }
    .header-links-popover-wrap {
      position: relative;
      display: inline-flex;
    }
    .devices-popover {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      width: 250px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 10px;
      box-shadow: 0 12px 24px rgba(26, 35, 56, 0.12);
      padding: .7rem;
      display: none;
      z-index: 70;
    }
    .devices-popover.show { display: block; }
    .device-item-btn {
      width: 100%;
      text-align: left;
      border: none;
      cursor: pointer;
      font-family: inherit;
      background: transparent;
    }
    .device-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .5rem .6rem;
      background: #f9fbfd;
      margin-bottom: .45rem;
    }
    .device-item:last-child { margin-bottom: 0; }
    .device-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .device-item span {
      display: block;
      font-size: 12px;
      color: #6b7280;
    }
    .device-item-btn:hover .device-item { border-color: #1a8fc1; background: #eef7fc; }

    /* Chart cards */
    .chart-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.2rem 1.4rem;
      margin-bottom: 1.2rem;
    }

    .chart-header {
      display: flex;
      align-items: center;
      gap: .8rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .chart-title {
      font-size: 15px;
      font-weight: 700;
      color: #1a1a2e;
      margin-right: auto;
      line-height: 1.3;
    }

    .period-btn {
      background: none;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 4px 14px;
      font-size: 12px;
      color: #6b7280;
      cursor: pointer;
      transition: all .15s;
      white-space: nowrap;
    }
    .period-btn.active {
      background: #fff;
      border-color: #1a1a2e;
      color: #1a1a2e;
      font-weight: 600;
    }
    .period-btn:hover:not(.active) { border-color: #1a8fc1; color: #1a8fc1; }

    /* Daily dropdown */
    .daily-dropdown {
      position: relative;
      display: inline-block;
    }
    .daily-btn {
      background: none;
      border: none;
      font-size: 12px;
      color: #6b7280;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 4px;
      font-family: 'Segoe UI', sans-serif;
      padding: 4px 6px;
    }
    .daily-btn:hover { color: #1a8fc1; }
    .daily-arrow { font-size: 10px; }

    .daily-menu {
      display: none;
      position: absolute;
      right: 0; top: 110%;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,.08);
      z-index: 10;
      min-width: 110px;
      overflow: hidden;
    }
    .daily-menu.open { display: block; }
    .daily-menu a {
      display: block;
      padding: 8px 14px;
      font-size: 12px;
      color: #4a5568;
      text-decoration: none;
      transition: background .12s;
    }
    .daily-menu a:hover { background: #f0f7fb; color: #1a8fc1; }

    .chart-wrap { position: relative; height: 210px; }
    .chart-wrap-sm { position: relative; height: 180px; }

    /* Bottom row */
    .bottom-row {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 1.2rem;
    }

    /* Stat cards */
    .stat-stack { display: flex; flex-direction: column; gap: 1rem; }

    .stat-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 12px;
      padding: 1rem 1.4rem 1.2rem;
      position: relative;
      overflow: hidden;
      flex: 1;
    }
    .stat-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .stat-label { font-size: 12px; color: #9aa3af; margin-bottom: 8px; }
    .stat-value { font-size: 24px; font-weight: 700; color: #1a1a2e; }
    .stat-unit  { font-size: 13px; font-weight: 400; color: #6b7280; margin-left: 2px; }
  <%- include('partials/glass-app-theme') %>
  </style>
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/monitoring" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Real-Time Monitoring
    </a>
    <a href="/water-quality" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6 9 4 13 4 16a8 8 0 0016 0c0-3-2-7-8-14z"/></svg>
      Water Quality
    </a>
    <a href="/consumption" class="nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Consumption
    </a>
    <a href="/alerts" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Alerts
    </a>
    <a href="/history" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/><rect x="2" y="3" width="4" height="4" rx="1"/><rect x="2" y="10" width="4" height="4" rx="1"/><rect x="2" y="17" width="4" height="4" rx="1"/></svg>
      History/Logs
    </a>
    <a href="/reports" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>
      Reports
    </a>
  </nav>
 
</aside>

<div class="main">
  <header class="topbar">
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge badge-indigo">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item">
            <strong>Flow Spike</strong>
            <span>Zone C flow exceeded normal range at 09:40 AM.</span>
          </li>
          <li class="popover-item">
            <strong>Usage Report</strong>
            <span>Daily consumption summary is ready for review.</span>
          </li>
          <li class="popover-item">
            <strong>Reminder</strong>
            <span>Check pump runtime logs before 5:00 PM.</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta">
            <strong>Admin User</strong>
            <span>admin@etubig.local</span>
          </div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">

  <!-- Page Header -->
  <div class="page-header">
    <div class="page-title">Water Consumption</div>
    <div class="device-name" id="deviceName">ESP DEVICE NAME</div>
    <div class="header-right">
      <div class="header-links">
        <div class="header-links-popover-wrap" data-device-wrap>
          <a href="#" id="devicesLink">Devices</a>
          <div class="devices-popover" id="devicesPopover"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Top Chart: Water Consumption Reports ── -->
  <div class="chart-card">
    <div class="chart-header">
      <span class="chart-title">Water Consumption Reports</span>
      <button class="period-btn active" onclick="switchPeriod(this, mainChart, mainData, '1h')">1 hour</button>
      <button class="period-btn" onclick="switchPeriod(this, mainChart, mainData, '5h')">5 hrs</button>
      <button class="period-btn" onclick="switchPeriod(this, mainChart, mainData, '8h')">8hrs</button>
      <button class="period-btn" onclick="switchPeriod(this, mainChart, mainData, '12h')">12 hours +</button>
      <div class="daily-dropdown">
        <button class="daily-btn" onclick="toggleDropdown()">
          Daily <span class="daily-arrow">▾</span>
        </button>
        <div class="daily-menu" id="dailyMenu">
          <a href="#" onclick="selectDaily('weekly')">Weekly</a>
          <a href="#" onclick="selectDaily('monthly')">Monthly</a>
          <a href="#" onclick="selectDaily('yearly')">Yearly</a>
        </div>
      </div>
    </div>
    <div class="chart-wrap">
      <canvas id="mainChart"></canvas>
    </div>
  </div>

  <!-- ── Bottom row: Today vs Yesterday + Stat Cards ── -->
  <div class="bottom-row">

    <div class="chart-card" style="margin-bottom:0;">
      <div class="chart-header">
        <span class="chart-title">Water Consumption Reports<br>(Today vs Yesterday)</span>
        <button class="period-btn active" onclick="switchPeriod(this, compChart, compData, '10am')">10 am</button>
        <button class="period-btn" onclick="switchPeriod(this, compChart, compData, '12nn')">12 nn</button>
        <button class="period-btn" onclick="switchPeriod(this, compChart, compData, '2pm')">2 pm</button>
        <button class="period-btn" onclick="switchPeriod(this, compChart, compData, '5pm')">5 pm</button>
      </div>
      <div class="chart-wrap-sm">
        <canvas id="compChart"></canvas>
      </div>
    </div>

    <div class="stat-stack">
      <div class="stat-card">
        <div class="stat-label">Flow Rate</div>
        <div class="stat-value" id="flowRateValue">50<span class="stat-unit">L/min</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Peak Usage Times</div>
        <div class="stat-value" id="peakUsageValue">12 nn</div>
      </div>
    </div>

  </div>

  </div>
</div>

<script>
  const months = ['Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan'];

  /* ─ Main chart data ─ */
  let mainData = {
    '1h':  { labels: Array.from({length:12}, (_,i)=>`${i*5}m`),
              d: [ Array.from({length:12}, (_,i)=>280+Math.sin(i*.5)*60+Math.random()*20) ] },
    '5h':  { labels: Array.from({length:10}, (_,i)=>`${i*30}m`),
              d: [ Array.from({length:10}, (_,i)=>300+Math.sin(i*.4)*70+Math.random()*25) ] },
    '8h':  { labels: months.slice(0,8),
              d: [ [290,310,350,380,400,420,460,500] ] },
    '12h': { labels: months,
              d: [ [270,290,320,360,400,410,430,470,510,490,540,580] ] },
  };

  /* ─ Comparison chart data ─ */
  let compData = {
    '10am': { labels: months,
               d: [
                 [200,220,240,260,300,310,330,360,400,390,420,450],
                 [160,175,190,210,240,250,265,290,320,310,335,360],
                 [120,130,140,155,175,180,195,210,235,225,245,260],
               ] },
    '12nn': { labels: months,
               d: [
                 [220,240,260,285,320,335,355,385,420,410,445,475],
                 [175,192,208,228,260,272,290,315,345,332,360,385],
                 [130,142,155,168,190,200,215,232,255,244,265,283],
               ] },
    '2pm':  { labels: months,
               d: [
                 [250,272,295,320,360,375,395,430,465,450,485,515],
                 [195,215,235,258,292,305,325,354,385,370,400,428],
                 [145,160,178,195,220,232,250,272,298,285,310,333],
               ] },
    '5pm':  { labels: months,
               d: [
                 [290,315,340,370,410,425,450,488,528,510,548,580],
                 [225,248,272,298,335,350,375,408,444,428,462,492],
                 [168,185,205,226,256,270,292,316,346,330,360,385],
               ] },
  };

  const blue1 = { line:'#2d3ac8', fill:'rgba(45,58,200,0.10)' };
  const blue2 = { line:'#6b8cff', fill:'rgba(107,140,255,0.08)' };
  const blue3 = { line:'#a5b4fc', fill:'rgba(165,180,252,0.06)' };
  const palette = [blue1, blue2, blue3];
  const deviceNameEl = document.getElementById('deviceName');
  const flowRateValueEl = document.getElementById('flowRateValue');
  const peakUsageValueEl = document.getElementById('peakUsageValue');
  let currentMainPeriod = '1h';
  let currentCompPeriod = '10am';

  const deviceProfiles = [
    {
      name: 'ESP-32 Main Tank',
      topic: 'etubig/main-tank/status',
      flowRate: 50,
      peakUsage: '12 nn',
      mainData,
      compData
    },
    {
      name: 'ESP-32 Zone C',
      topic: 'etubig/zone-c/status',
      flowRate: 58,
      peakUsage: '2 pm',
      mainData: {
        '1h':  { labels: Array.from({length:12}, (_,i)=>`${i*5}m`), d: [ Array.from({length:12}, (_,i)=>330+Math.sin(i*.5)*62+Math.random()*24) ] },
        '5h':  { labels: Array.from({length:10}, (_,i)=>`${i*30}m`), d: [ Array.from({length:10}, (_,i)=>350+Math.sin(i*.4)*78+Math.random()*28) ] },
        '8h':  { labels: months.slice(0,8), d: [ [340,360,390,420,440,470,510,550] ] },
        '12h': { labels: months, d: [ [320,340,370,410,440,460,490,530,565,550,590,630] ] },
      },
      compData: {
        '10am': { labels: months, d: [[240,265,285,310,340,355,380,410,450,435,470,500],[190,205,225,248,280,290,310,335,370,355,380,410],[145,156,168,186,210,218,235,255,280,270,292,312]] },
        '12nn': { labels: months, d: [[260,285,308,334,365,380,405,435,470,455,492,525],[205,223,245,270,305,318,338,365,395,380,410,438],[152,166,182,202,228,238,258,279,304,292,316,338]] },
        '2pm':  { labels: months, d: [[285,310,336,364,398,415,440,472,510,495,532,565],[223,245,268,292,328,344,366,398,432,415,450,478],[166,183,202,222,250,264,286,310,340,325,352,375]] },
        '5pm':  { labels: months, d: [[315,342,370,400,438,455,482,520,560,542,582,615],[248,272,298,326,364,382,408,442,478,462,498,530],[185,204,226,248,280,294,320,346,378,362,392,418]] },
      }
    },
    {
      name: 'ESP-8266 Pump House',
      topic: 'etubig/pump-house/status',
      flowRate: 43,
      peakUsage: '10 am',
      mainData: {
        '1h':  { labels: Array.from({length:12}, (_,i)=>`${i*5}m`), d: [ Array.from({length:12}, (_,i)=>230+Math.sin(i*.5)*50+Math.random()*16) ] },
        '5h':  { labels: Array.from({length:10}, (_,i)=>`${i*30}m`), d: [ Array.from({length:10}, (_,i)=>245+Math.sin(i*.4)*58+Math.random()*20) ] },
        '8h':  { labels: months.slice(0,8), d: [ [240,255,280,300,325,340,370,395] ] },
        '12h': { labels: months, d: [ [225,242,260,285,310,322,345,375,402,390,420,448] ] },
      },
      compData: {
        '10am': { labels: months, d: [[172,190,205,226,255,265,282,305,338,327,352,374],[138,150,166,184,208,216,232,252,280,268,290,310],[102,112,122,136,154,160,173,188,208,198,215,230]] },
        '12nn': { labels: months, d: [[185,205,220,243,272,283,300,324,356,346,372,395],[148,162,178,198,222,232,250,272,300,288,312,334],[110,122,132,146,166,174,188,205,226,216,234,250]] },
        '2pm':  { labels: months, d: [[205,225,243,265,295,306,325,352,385,372,400,425],[164,180,196,218,245,256,276,300,330,318,344,368],[122,134,146,162,184,192,208,226,248,238,258,276]] },
        '5pm':  { labels: months, d: [[228,248,266,292,322,336,356,385,418,402,430,455],[182,198,216,238,266,278,298,324,354,340,366,392],[135,148,162,180,204,214,230,250,274,262,282,302]] },
      }
    }
  ];
  let activeDevice = deviceProfiles[0];

  function buildDatasets(d) {
    return d.d.map((pts, i) => ({
      data: pts,
      borderColor: palette[i].line,
      backgroundColor: palette[i].fill,
      fill: true,
      tension: 0.5,
      borderWidth: i === 0 ? 2.5 : 1.5,
      pointRadius: 0,
    }));
  }

  const commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    animation: { duration: 350 },
    plugins: { legend: { display: false } },
    scales: {
      x: { grid: { display: false }, ticks: { color: '#9aa3af', font: { size: 11 } } },
      y: { display: false },
    },
  };

  // Main chart
  const mainCtx = document.getElementById('mainChart').getContext('2d');
  const mainChart = new Chart(mainCtx, {
    type: 'line',
    data: { labels: mainData['1h'].labels, datasets: buildDatasets(mainData['1h']) },
    options: commonOptions,
  });

  // Comparison chart
  const compCtx = document.getElementById('compChart').getContext('2d');
  const compChart = new Chart(compCtx, {
    type: 'line',
    data: { labels: compData['10am'].labels, datasets: buildDatasets(compData['10am']) },
    options: commonOptions,
  });

  function switchPeriod(btn, chart, dataMap, key) {
    btn.closest('.chart-header').querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if (chart === mainChart) currentMainPeriod = key;
    if (chart === compChart) currentCompPeriod = key;
    const d = dataMap[key];
    chart.data.labels   = d.labels;
    chart.data.datasets = buildDatasets(d);
    chart.update();
  }

  function applyDeviceProfile(device) {
    activeDevice = device;
    mainData = device.mainData;
    compData = device.compData;
    if (deviceNameEl) deviceNameEl.textContent = device.name;
    if (flowRateValueEl) flowRateValueEl.innerHTML = `${device.flowRate}<span class="stat-unit">L/min</span>`;
    if (peakUsageValueEl) peakUsageValueEl.textContent = device.peakUsage;

    const mainSelected = mainData[currentMainPeriod] || mainData['1h'];
    const compSelected = compData[currentCompPeriod] || compData['10am'];
    mainChart.data.labels = mainSelected.labels;
    mainChart.data.datasets = buildDatasets(mainSelected);
    compChart.data.labels = compSelected.labels;
    compChart.data.datasets = buildDatasets(compSelected);
    mainChart.update();
    compChart.update();
  }

  /* Daily dropdown */
  function toggleDropdown() {
    document.getElementById('dailyMenu').classList.toggle('open');
  }
  function selectDaily(period) {
    document.getElementById('dailyMenu').classList.remove('open');
    // extend mainData with weekly/monthly/yearly as needed
  }
  document.addEventListener('click', e => {
    if (!e.target.closest('.daily-dropdown'))
      document.getElementById('dailyMenu').classList.remove('open');
  });

  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');
  const devicesLink = document.getElementById('devicesLink');
  const devicesPopover = document.getElementById('devicesPopover');
  const activeEspDevices = deviceProfiles;

  if (devicesPopover) {
    devicesPopover.innerHTML = activeEspDevices
      .map((device, index) => `<button type="button" class="device-item-btn" data-device-index="${index}"><div class="device-item"><strong>${device.name}</strong><span>MQTT: ${device.topic}</span></div></button>`)
      .join('');
  }

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  if (devicesLink && devicesPopover) {
    devicesLink.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      const isOpen = devicesPopover.classList.contains('show');
      closeAllPopovers();
      devicesPopover.classList.toggle('show', !isOpen);
    });

    devicesPopover.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-device-index]');
      if (!btn) return;
      const idx = Number(btn.getAttribute('data-device-index'));
      if (Number.isNaN(idx) || !activeEspDevices[idx]) return;
      applyDeviceProfile(activeEspDevices[idx]);
      devicesPopover.classList.remove('show');
    });
  }

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) {
      closeAllPopovers();
    }
    if (!event.target.closest('[data-device-wrap]')) {
      devicesPopover && devicesPopover.classList.remove('show');
    }
  });

  applyDeviceProfile(activeDevice);
</script>
</body>
</html>
