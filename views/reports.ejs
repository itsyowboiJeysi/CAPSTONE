  </nav>
 
</aside>

<div class="main">
  <header class="topbar">
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item"><strong>Report Queue</strong><span>2 reports are waiting export.</span></li>
          <li class="popover-item"><strong>Data Sync</strong><span>Latest sensor data loaded.</span></li>
        </ul>
      </div>
    </div>
    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta"><strong>Admin User</strong><span>admin@etubig.local</span></div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">
    <div class="header-row">
      <div>
        <h1 class="page-title">Reports</h1>
        <p class="page-subtitle">Create analysis reports and export to PDF</p>
      </div>
    </div>

    <div class="reports-layout">
      <div class="card">
        <div class="panel-title">Data Fields (Drag to Report)</div>
        <div class="data-list">
          <div class="device-picker">
            <button class="data-pill device-pill" id="deviceNamePill" type="button" draggable="true" data-token="">Device Name</button>
            <div class="device-menu" id="deviceMenu"></div>
          </div>
          <div class="snapshot-controls">
            <input id="snapshotDate" type="date" />
            <input id="snapshotTime" type="time" />
          </div>
          <div class="data-pill" draggable="true" data-field="timestamp" data-token="">Timestamp</div>
          <div class="data-pill" draggable="true" data-field="ph" data-token="">pH Level</div>
          <div class="data-pill" draggable="true" data-field="turbidity" data-token="">Turbidity</div>
          <div class="data-pill" draggable="true" data-field="temperature" data-token="">Temperature</div>
          <div class="data-pill" draggable="true" data-field="flow" data-token="">Flow Rate</div>
          <div class="data-pill" draggable="true" data-field="status" data-token="">Status</div>
          <div class="data-pill" draggable="true" data-field="alerts" data-token="">Alert Summary</div>
        </div>
        <p class="helper">Drag any data item into the report editor area. You can format text like in Word using the toolbar on the right.</p>
      </div>

      <div class="card">
        <div class="form-grid">
          <div class="field">
            <label for="reportTitle">Report Title</label>
            <input id="reportTitle" type="text" value="Water Quality and Consumption Analysis Report" />
          </div>
          <div class="field">
            <label for="reportType">Report Type</label>
            <select id="reportType">
              <option>Daily Summary</option>
              <option>Weekly Analysis</option>
              <option>Monthly Compliance</option>
            </select>
          </div>
          <div class="field">
            <label for="reportDate">Report Date</label>
            <input id="reportDate" type="date" />
          </div>
        </div>

        <div class="toolbar">
          <button class="tool-btn" type="button" data-cmd="bold"><b>B</b></button>
          <button class="tool-btn" type="button" data-cmd="italic"><i>I</i></button>
          <button class="tool-btn" type="button" data-cmd="underline"><u>U</u></button>
          <button class="tool-btn" type="button" data-cmd="insertUnorderedList">• List</button>
          <button class="tool-btn" type="button" data-cmd="insertOrderedList">1. List</button>
          <button class="tool-btn" type="button" data-cmd="justifyLeft">Left</button>
          <button class="tool-btn" type="button" data-cmd="justifyCenter">Center</button>
          <button class="tool-btn" type="button" data-cmd="justifyRight">Right</button>
        </div>
        <div id="reportEditor" class="editor" contenteditable="true">
          <h3>Executive Summary</h3>
          <p>Drag data fields from the left side and drop them here to build your report.</p>
          <p>Current findings indicate stable quality metrics with manageable alert activity.</p>
        </div>

        <div class="actions">
          <button class="btn" id="clearReportBtn" type="button">Clear</button>
          <button class="btn primary" id="exportPdfBtn" type="button">Export to PDF</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('reportDate').valueAsDate = new Date();

  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');
  function closeAllPopovers() { popovers.forEach((p) => p.classList.remove('show')); }
  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetPopover = document.querySelector(`[data-popover-id="${toggle.getAttribute('data-popover-toggle')}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });
  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) closeAllPopovers();
  });

  const editor = document.getElementById('reportEditor');
  const dataPills = document.querySelectorAll('.data-pill');
  const deviceNamePill = document.getElementById('deviceNamePill');
  const deviceMenu = document.getElementById('deviceMenu');
  const snapshotDateInput = document.getElementById('snapshotDate');
  const snapshotTimeInput = document.getElementById('snapshotTime');
  const deviceProfiles = {
    'ESP-32 Main Tank': {
      history: [
        { iso: '2026-04-24T08:30', timestamp: 'Apr 24, 08:30 AM', ph: '7.0 pH', turbidity: '2.4 NTU', temperature: '24 C', flow: '47 L/min', status: 'Normal', alerts: '1 Active' },
        { iso: '2026-04-25T14:20', timestamp: 'Apr 25, 02:20 PM', ph: '7.3 pH', turbidity: '2.0 NTU', temperature: '23 C', flow: '50 L/min', status: 'Normal', alerts: '2 Active' },
        { iso: '2026-04-26T09:42', timestamp: 'Apr 26, 09:42 AM', ph: '7.2 pH', turbidity: '2.1 NTU', temperature: '23 C', flow: '50 L/min', status: 'Normal', alerts: '2 Active' }
      ]
    },
    'ESP-32 Zone A': {
      history: [
        { iso: '2026-04-24T07:45', timestamp: 'Apr 24, 07:45 AM', ph: '7.1 pH', turbidity: '2.8 NTU', temperature: '25 C', flow: '53 L/min', status: 'Warning', alerts: '3 Active' },
        { iso: '2026-04-25T16:10', timestamp: 'Apr 25, 04:10 PM', ph: '6.9 pH', turbidity: '3.2 NTU', temperature: '26 C', flow: '57 L/min', status: 'Warning', alerts: '4 Active' },
        { iso: '2026-04-26T09:58', timestamp: 'Apr 26, 09:58 AM', ph: '6.8 pH', turbidity: '3.4 NTU', temperature: '26 C', flow: '58 L/min', status: 'Warning', alerts: '4 Active' }
      ]
    },
    'ESP-8266 Intake': {
      history: [
        { iso: '2026-04-24T10:00', timestamp: 'Apr 24, 10:00 AM', ph: '7.6 pH', turbidity: '1.5 NTU', temperature: '22 C', flow: '42 L/min', status: 'Normal', alerts: '1 Active' },
        { iso: '2026-04-25T11:30', timestamp: 'Apr 25, 11:30 AM', ph: '7.8 pH', turbidity: '1.3 NTU', temperature: '22 C', flow: '43 L/min', status: 'Normal', alerts: '1 Active' },
        { iso: '2026-04-26T08:15', timestamp: 'Apr 26, 08:15 AM', ph: '7.9 pH', turbidity: '1.2 NTU', temperature: '22 C', flow: '44 L/min', status: 'Normal', alerts: '1 Active' }
      ]
    }
  };
  let activeDevice = 'ESP-32 Main Tank';

  function formatSelectedTimestamp(dateStr, timeStr) {
    if (!dateStr || !timeStr) return '';
    const dt = new Date(`${dateStr}T${timeStr}`);
    if (Number.isNaN(dt.getTime())) return '';
    const month = dt.toLocaleString('en-US', { month: 'short' });
    const day = dt.getDate();
    const year = dt.getFullYear();
    const hh = dt.toLocaleString('en-US', { hour: '2-digit', hour12: false });
    const mm = dt.toLocaleString('en-US', { minute: '2-digit', hour12: false });
    const period = Number(hh) >= 12 ? 'PM' : 'AM';
    const hr12 = ((Number(hh) + 11) % 12) + 1;
    const hrText = hr12 < 10 ? `${hr12}` : `${hr12}`;
    return `${month} ${day}, ${year} ${hrText}:${mm} ${period}`;
  }

  function seededValue(seed) {
    const x = Math.sin(seed) * 10000;
    return x - Math.floor(x);
  }

  function buildMockSnapshot(deviceName, dateStr, timeStr) {
    const history = deviceProfiles[deviceName]?.history || [];
    const fallback = history.length ? history[history.length - 1] : null;
    if (!fallback) return null;
    if (!dateStr || !timeStr) return fallback;

    const selectedTs = formatSelectedTimestamp(dateStr, timeStr);
    const seedBase = new Date(`${dateStr}T${timeStr}`).getTime() / 60000;
    const deviceSeed = deviceName.length * 31;
    const s1 = seededValue(seedBase + deviceSeed);
    const s2 = seededValue(seedBase + deviceSeed + 19);
    const s3 = seededValue(seedBase + deviceSeed + 47);
    const s4 = seededValue(seedBase + deviceSeed + 83);

    const basePh = parseFloat(fallback.ph);
    const baseTurbidity = parseFloat(fallback.turbidity);
    const baseTemp = parseFloat(fallback.temperature);
    const baseFlow = parseFloat(fallback.flow);

    const ph = (basePh + (s1 - 0.5) * 0.6).toFixed(1);
    const turbidity = (baseTurbidity + (s2 - 0.5) * 1.0).toFixed(1);
    const temp = Math.max(18, Math.round(baseTemp + (s3 - 0.5) * 4));
    const flow = Math.max(30, Math.round(baseFlow + (s4 - 0.5) * 10));
    const alertCount = Math.max(0, Math.round((parseFloat(fallback.alerts) || 0) + (s2 - 0.5) * 2));

    return {
      timestamp: selectedTs,
      ph: `${ph} pH`,
      turbidity: `${turbidity} NTU`,
      temperature: `${temp} C`,
      flow: `${flow} L/min`,
      status: parseFloat(turbidity) > 3 || parseFloat(ph) < 6.8 || parseFloat(ph) > 8.2 ? 'Warning' : 'Normal',
      alerts: `${alertCount} Active`,
    };
  }

  function findSnapshot(deviceName) {
    const selectedDate = snapshotDateInput?.value || '';
    const selectedTime = snapshotTimeInput?.value || '';
    return buildMockSnapshot(deviceName, selectedDate, selectedTime);
  }

  function applyDeviceProfile(deviceName) {
    const profile = deviceProfiles[deviceName];
    if (!profile) return;
    activeDevice = deviceName;
    const snapshot = findSnapshot(deviceName);
    if (!snapshot) return;

    if (deviceNamePill) {
      deviceNamePill.textContent = `Device Name: ${deviceName} ▾`;
      deviceNamePill.setAttribute('data-token', `Device: ${deviceName}`);
    }

    document.querySelectorAll('[data-field]').forEach((pill) => {
      const field = pill.getAttribute('data-field');
      const value = snapshot[field];
      if (!value) return;
      const labels = {
        timestamp: 'Timestamp',
        ph: 'pH Level',
        turbidity: 'Turbidity',
        temperature: 'Temperature',
        flow: 'Flow Rate',
        status: 'Status',
        alerts: 'Alert Count'
      };
      pill.setAttribute('data-token', `${labels[field]}: ${value}`);
      pill.textContent = `${labels[field]}: ${value}`;
    });
  }

  if (deviceMenu) {
    deviceMenu.innerHTML = Object.keys(deviceProfiles)
      .map((name) => `<button type="button" class="device-option" data-device="${name}">${name}</button>`)
      .join('');
  }

  if (deviceNamePill && deviceMenu) {
    deviceNamePill.addEventListener('click', () => {
      deviceMenu.classList.toggle('show');
    });
    deviceMenu.addEventListener('click', (event) => {
      const option = event.target.closest('[data-device]');
      if (!option) return;
      applyDeviceProfile(option.getAttribute('data-device'));
      deviceMenu.classList.remove('show');
    });
  }

  if (snapshotDateInput && snapshotTimeInput) {
    const latest = deviceProfiles[activeDevice].history.slice(-1)[0];
    snapshotDateInput.value = latest.iso.split('T')[0];
    snapshotTimeInput.value = latest.iso.split('T')[1];
    snapshotDateInput.addEventListener('change', () => applyDeviceProfile(activeDevice));
    snapshotTimeInput.addEventListener('change', () => applyDeviceProfile(activeDevice));
  }

  applyDeviceProfile(activeDevice);

  dataPills.forEach((pill) => {
    pill.addEventListener('dragstart', (event) => {
      event.dataTransfer.setData('text/plain', pill.getAttribute('data-token'));
    });
  });

  editor.addEventListener('dragover', (event) => {
    event.preventDefault();
    editor.classList.add('drop-target');
  });
  editor.addEventListener('dragleave', () => editor.classList.remove('drop-target'));
  editor.addEventListener('drop', (event) => {
    event.preventDefault();
    editor.classList.remove('drop-target');
    const token = event.dataTransfer.getData('text/plain');
    if (!token) return;
    document.execCommand('insertText', false, `${token} `);
  });

  document.querySelectorAll('[data-cmd]').forEach((btn) => {
    btn.addEventListener('click', () => {
      editor.focus();
      document.execCommand(btn.getAttribute('data-cmd'), false, null);
    });
  });

  document.getElementById('clearReportBtn').addEventListener('click', () => {
    editor.innerHTML = '<p></p>';
    editor.focus();
  });

  document.getElementById('exportPdfBtn').addEventListener('click', () => {
    const title = document.getElementById('reportTitle').value || 'Report';
    const type = document.getElementById('reportType').value || '';
    const date = document.getElementById('reportDate').value || '';
    const content = editor.innerHTML;

    const printWindow = window.open('', '_blank', 'width=900,height=700');
    if (!printWindow) return;
    printWindow.document.write(`
      <html>
      <head>
        <title>${title}</title>
        <style>
          body { font-family: Segoe UI, sans-serif; padding: 28px; color: #111827; }
          h1 { margin-bottom: 8px; font-size: 24px; }
          .meta { margin-bottom: 18px; color: #4b5563; font-size: 13px; }
          .paper { border: 1px solid #e5e7eb; border-radius: 8px; padding: 18px; }
        </style>
      </head>
      <body>
        <h1>${title}</h1>
        <div class="meta">Type: ${type} | Date: ${date}</div>
        <div class="paper">${content}</div>
      </body>
      </html>
    `);
    printWindow.document.close();
    printWindow.focus();
    printWindow.print();
  });

  document.addEventListener('click', (event) => {
    if (!event.target.closest('.device-picker') && deviceMenu) {
      deviceMenu.classList.remove('show');
    }
  });
</script>
</body>
</html>
