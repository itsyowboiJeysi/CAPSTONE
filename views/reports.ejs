<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Reports</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    .main::-webkit-scrollbar,
    .content::-webkit-scrollbar,
    .sidebar::-webkit-scrollbar { display: none; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
    }

    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }
    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
    .sidebar-bottom {
      padding: 1rem 0;
      border-top: 1px solid #f0f4f8;
    }

    .main {
      margin-left: 210px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      cursor: pointer;
      color: #6b7280;
    }
    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }
    .topbar-action { position: relative; }
    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      background: #5b5fcf;
    }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
      cursor: pointer;
    }
    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }
    .topbar-popover.show { display: block; }
    .popover-title { font-size: 13px; font-weight: 700; margin-bottom: .65rem; }
    .popover-list { list-style: none; display: flex; flex-direction: column; gap: .45rem; }
    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .popover-item strong { display: block; font-size: 12px; margin-bottom: 2px; }
    .popover-item span { font-size: 12px; color: #6b7280; }

    .avatar-panel { width: 250px; }
    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }
    .avatar-chip {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
    }
    .avatar-meta strong { display: block; font-size: 13px; }
    .avatar-meta span { font-size: 12px; color: #6b7280; }
    .avatar-actions { display: flex; flex-direction: column; gap: .35rem; }
    .avatar-actions a { text-decoration: none; font-size: 12px; color: #1a8fc1; font-weight: 600; }

    .content { padding: 1.6rem 2rem; flex: 1; }
    .header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 1rem;
      gap: 1rem;
    }
    .page-title { font-size: 30px; font-weight: 700; }
    .page-subtitle { font-size: 20px; color: #5f6b7a; }

    .reports-layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 1rem;
    }
    .card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1rem;
    }
    .panel-title { font-size: 14px; font-weight: 700; margin-bottom: .7rem; }
    .data-list { display: flex; flex-direction: column; gap: .5rem; }
    .device-picker { position: relative; }
    .data-pill {
      border: 1px dashed #93c5e8;
      background: #f4fbff;
      border-radius: 8px;
      padding: .55rem .65rem;
      font-size: 12px;
      color: #256a93;
      cursor: grab;
      user-select: none;
    }
    .device-pill {
      width: 100%;
      text-align: left;
      font-family: inherit;
      border-style: solid;
      cursor: pointer;
      color: #1d5f87;
      font-weight: 600;
    }
    .device-menu {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      background: #fff;
      border: 1px solid #d7dde5;
      border-radius: 8px;
      box-shadow: 0 10px 20px rgba(26, 35, 56, 0.12);
      display: none;
      z-index: 90;
      overflow: hidden;
    }
    .device-menu.show { display: block; }
    .device-option {
      width: 100%;
      border: none;
      background: #fff;
      text-align: left;
      padding: 8px 10px;
      font-size: 12px;
      color: #2d3748;
      cursor: pointer;
      font-family: inherit;
    }
    .device-option:hover { background: #f0f7fb; color: #1a8fc1; }
    .snapshot-controls {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .4rem;
      margin-bottom: .1rem;
    }
    .snapshot-controls input {
      width: 100%;
      border: 1px solid #d7dde5;
      border-radius: 7px;
      padding: 6px 8px;
      font-size: 12px;
      color: #2d3748;
      font-family: inherit;
      outline: none;
      background: #fff;
    }
    .helper { font-size: 11px; color: #6b7280; margin-top: .65rem; line-height: 1.4; }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: .75rem;
      margin-bottom: .75rem;
    }
    .field label { display: block; font-size: 11px; color: #718096; margin-bottom: 4px; }
    .field input, .field select {
      width: 100%;
      border: 1px solid #d7dde5;
      border-radius: 8px;
      padding: 8px 10px;
      font-size: 13px;
      outline: none;
      font-family: inherit;
    }

    .toolbar {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      border: 1px solid #d7dde5;
      border-radius: 10px 10px 0 0;
      border-bottom: none;
      padding: .55rem;
      background: #f9fbfd;
    }
    .tool-btn {
      border: 1px solid #d7dde5;
      background: #fff;
      border-radius: 6px;
      padding: 4px 8px;
      font-size: 12px;
      cursor: pointer;
      color: #4a5568;
    }
    .editor {
      min-height: 320px;
      border: 1px solid #d7dde5;
      border-radius: 0 0 10px 10px;
      background: #fff;
      padding: .9rem;
      outline: none;
      font-size: 14px;
      line-height: 1.5;
    }
    .editor.drop-target { border-color: #1a8fc1; background: #f2faff; }

    .actions {
      margin-top: .8rem;
      display: flex;
      justify-content: flex-end;
      gap: .55rem;
    }
    .btn {
      border: 1px solid #d7dde5;
      background: #fff;
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 12px;
      cursor: pointer;
      color: #4a5568;
      font-weight: 600;
    }
    .btn.primary {
      border-color: #1a8fc1;
      background: #1a8fc1;
      color: #fff;
    }
  </style>
</head>
<body>
<aside class="sidebar">
  <div class="sidebar-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Dashboard</a>
    <a href="/monitoring" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>Real-Time Monitoring</a>
    <a href="/water-quality" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6 9 4 13 4 16a8 8 0 0016 0c0-3-2-7-8-14z"/></svg>Water Quality</a>
    <a href="/consumption" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Consumption</a>
    <a href="/alerts" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>Alerts</a>
    <a href="/history" class="nav-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/><rect x="2" y="3" width="4" height="4" rx="1"/><rect x="2" y="10" width="4" height="4" rx="1"/><rect x="2" y="17" width="4" height="4" rx="1"/></svg>History/Logs</a>
