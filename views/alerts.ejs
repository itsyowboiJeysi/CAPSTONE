<div class="main">
  <header class="topbar">
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item">
            <strong>High Turbidity</strong>
            <span>Sensor reported 6.8 NTU above safe limit.</span>
          </li>
          <li class="popover-item">
            <strong>pH Warning</strong>
            <span>pH level rose to 9.2 in Zone A line.</span>
          </li>
          <li class="popover-item">
            <strong>Temperature Spike</strong>
            <span>42C anomaly has been marked resolved.</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta">
            <strong>Admin User</strong>
            <span>admin@etubig.local</span>
          </div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">
    <div class="header-row">
      <h1 class="title">Alerts</h1>
      <div>
        <button class="date-label" id="dateSortBtn" type="button">Date</button>
        <input class="hidden-date-input" id="datePickerInput" type="date" />
      </div>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th style="width: 26%;">ALERT</th>
            <th style="width: 34%;">DESCRIPTION</th>
            <th style="width: 16%;">STATUS</th>
            <th style="width: 16%;" class="sortable-date" id="tableDateHead">TIME AND DATE</th>
            <th style="width: 8%;"></th>
          </tr>
        </thead>
        <tbody id="alertsTableBody">
          <tr>
            <td>High Turbidity Detected</td>
            <td>Value: 6.8 NTU (Above safe limit)</td>
            <td><span class="status-pill status-active"><span class="status-icon">X</span>ACTIVE</span></td>
            <td>Dec 30, 09:42 PM</td>
            <td class="action-cell">
              <button type="button" class="action-btn" data-row-action>...</button>
              <div class="action-menu">
                <button type="button" class="action-item" data-action="delete">Delete alert</button>
                <button type="button" class="action-item" data-action="pdf">Export to PDF</button>
                <button type="button" class="action-item" data-action="time-data">View data at this time</button>
              </div>
            </td>
          </tr>
          <tr>
            <td>pH Level Out of Range</td>
            <td>Value: 9.2 pH (Too alkaline)</td>
            <td><span class="status-pill status-active"><span class="status-icon">X</span>ACTIVE</span></td>
            <td>Apr 22, 09:58 AM</td>
            <td class="action-cell">
              <button type="button" class="action-btn" data-row-action>...</button>
              <div class="action-menu">
                <button type="button" class="action-item" data-action="delete">Delete alert</button>
                <button type="button" class="action-item" data-action="pdf">Export to PDF</button>
                <button type="button" class="action-item" data-action="time-data">View data at this time</button>
              </div>
            </td>
          </tr>
          <tr>
            <td>Temperature Spike Detected</td>
            <td>Value: 42C</td>
            <td><span class="status-pill status-resolved"><span class="status-icon">✓</span>RESOLVED</span></td>
            <td>Apr 21, 04:12 PM</td>
            <td class="action-cell">
              <button type="button" class="action-btn" data-row-action>...</button>
              <div class="action-menu">
                <button type="button" class="action-item" data-action="delete">Delete alert</button>
                <button type="button" class="action-item" data-action="pdf">Export to PDF</button>
                <button type="button" class="action-item" data-action="time-data">View data at this time</button>
              </div>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
<div class="time-data-modal" id="timeDataModal">
  <div class="time-data-card">
    <div class="time-data-head">
      <div class="time-data-title">Sensor Snapshot</div>
      <button type="button" class="time-data-close" id="timeDataClose">×</button>
    </div>
    <div class="time-data-sub" id="timeDataSub"></div>
    <div class="time-data-grid" id="timeDataGrid"></div>
  </div>
</div>
<script>
  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) closeAllPopovers();
  });

  const tbody = document.getElementById('alertsTableBody');
  const dateSortBtn = document.getElementById('dateSortBtn');
  const tableDateHead = document.getElementById('tableDateHead');
  const datePickerInput = document.getElementById('datePickerInput');
  let isDateAsc = false;

  function parseDateCell(text) {
    return new Date(text.replace(',', '')).getTime();
  }

  function sortRowsByDate() {
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
      const aDate = parseDateCell(a.children[3].textContent.trim());
      const bDate = parseDateCell(b.children[3].textContent.trim());
      return isDateAsc ? aDate - bDate : bDate - aDate;
    });
    rows.forEach((row) => tbody.appendChild(row));
    const arrow = isDateAsc ? '↑' : '↓';
    if (dateSortBtn) dateSortBtn.textContent = `Date ${arrow}`;
    if (tableDateHead) tableDateHead.textContent = `TIME AND DATE ${arrow}`;
  }

  function toggleDateSort() {
    isDateAsc = !isDateAsc;
    sortRowsByDate();
  }

  function monthDayFromDateInput(value) {
    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return '';
    const month = d.toLocaleString('en-US', { month: 'short' });
    const day = d.getDate();
    return `${month} ${day}`;
  }

  function filterRowsBySelectedDate() {
    if (!tbody || !datePickerInput) return;
    const key = monthDayFromDateInput(datePickerInput.value);
    const rows = Array.from(tbody.querySelectorAll('tr'));

    rows.forEach((row) => {
      const rowDate = row.children[3].textContent.trim();
      row.style.display = !key || rowDate.startsWith(key) ? '' : 'none';
    });

    if (dateSortBtn) dateSortBtn.textContent = key || 'Date';
  }

  if (dateSortBtn && datePickerInput) {
    dateSortBtn.addEventListener('click', () => {
      if (typeof datePickerInput.showPicker === 'function') {
        datePickerInput.showPicker();
      } else {
        datePickerInput.click();
      }
    });
    datePickerInput.addEventListener('change', filterRowsBySelectedDate);
  }

  if (tableDateHead) tableDateHead.addEventListener('click', toggleDateSort);

  const timeDataModal = document.getElementById('timeDataModal');
  const timeDataSub = document.getElementById('timeDataSub');
  const timeDataGrid = document.getElementById('timeDataGrid');
  const timeDataClose = document.getElementById('timeDataClose');

  function closeAllRowMenus() {
    document.querySelectorAll('.action-menu').forEach((menu) => menu.classList.remove('show'));
  }

  function ensureRowActions() {
    if (!tbody) return;
    tbody.querySelectorAll('tr').forEach((row) => {
      const actionCell = row.lastElementChild;
      if (!actionCell || actionCell.querySelector('[data-row-action]')) return;
      actionCell.classList.add('action-cell');
      actionCell.innerHTML = `
        <button type="button" class="action-btn" data-row-action>...</button>
        <div class="action-menu">
          <button type="button" class="action-item" data-action="delete">Delete alert</button>
          <button type="button" class="action-item" data-action="pdf">Export to PDF</button>
          <button type="button" class="action-item" data-action="time-data">View data at this time</button>
        </div>
      `;
    });
  }

  if (tbody) {
    tbody.addEventListener('click', (event) => {
      const actionBtn = event.target.closest('[data-row-action]');
      if (actionBtn) {
        event.stopPropagation();
        const menu = actionBtn.parentElement.querySelector('.action-menu');
        const isOpen = menu && menu.classList.contains('show');
        closeAllRowMenus();
        if (menu && !isOpen) {
          menu.classList.remove('open-up');
          const btnRect = actionBtn.getBoundingClientRect();
          const spaceBelow = window.innerHeight - btnRect.bottom;
          if (spaceBelow < 150) menu.classList.add('open-up');
          menu.classList.add('show');
        }
        return;
      }

      const actionItem = event.target.closest('.action-item');
      if (!actionItem) return;
      const row = actionItem.closest('tr');
      if (!row) return;
      const action = actionItem.getAttribute('data-action');
      const alertName = row.children[0].textContent.trim();
      const alertDesc = row.children[1].textContent.trim();
      const alertTime = row.children[3].textContent.trim();

      if (action === 'delete') {
        row.remove();
      } else if (action === 'pdf') {
        window.print();
      } else if (action === 'time-data') {
        const mockSnapshot = {
          'High Turbidity Detected': { 'Turbidity': '6.8 NTU', 'pH Level': '7.4 pH', 'Temperature': '29 C', 'Flow Rate': '52 L/min' },
          'pH Level Out of Range': { 'pH Level': '9.2 pH', 'Turbidity': '1.9 NTU', 'Temperature': '26 C', 'Flow Rate': '49 L/min' },
          'Temperature Spike Detected': { 'Temperature': '42 C', 'pH Level': '7.1 pH', 'Turbidity': '2.5 NTU', 'Flow Rate': '45 L/min' }
        };
        const values = mockSnapshot[alertName] || { 'Description': alertDesc, 'Timestamp': alertTime };
        if (timeDataSub) timeDataSub.textContent = `${alertName} - ${alertTime}`;
        if (timeDataGrid) {
          timeDataGrid.innerHTML = Object.entries(values)
            .map(([key, value]) => `<div class="time-data-item"><strong>${key}</strong><span>${value}</span></div>`)
            .join('');
        }
        if (timeDataModal) timeDataModal.classList.add('show');
      }
      closeAllRowMenus();
      if (action === 'pdf') alert(`Export PDF requested for: ${alertName}`);
    });
  }

  document.addEventListener('click', () => closeAllRowMenus());
  if (timeDataClose) timeDataClose.addEventListener('click', () => timeDataModal && timeDataModal.classList.remove('show'));
  if (timeDataModal) {
    timeDataModal.addEventListener('click', (event) => {
      if (event.target === timeDataModal) timeDataModal.classList.remove('show');
    });
  }
  ensureRowActions();
</script>
</body>
</html>
