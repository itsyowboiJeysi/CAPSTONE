<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Alerts</title>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    .main::-webkit-scrollbar,
    .content::-webkit-scrollbar { display: none; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
    }

    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }
    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
    .sidebar-bottom {
      padding: 1rem 0;
      border-top: 1px solid #f0f4f8;
    }

    .main {
      margin-left: 210px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      color: #6b7280;
      cursor: pointer;
    }
    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }
    .topbar-action { position: relative; }
    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }
    .topbar-popover.show { display: block; }
    .popover-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .65rem;
    }
    .popover-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .45rem;
    }
    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .popover-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .popover-item span {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.35;
      display: block;
    }
    .avatar-panel { width: 250px; }
    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }
    .avatar-chip {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }
    .avatar-meta strong {
      display: block;
      font-size: 13px;
      color: #1a1a2e;
    }
    .avatar-meta span {
      font-size: 12px;
      color: #6b7280;
    }
    .avatar-actions {
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }
    .avatar-actions a {
      text-decoration: none;
      font-size: 12px;
      color: #1a8fc1;
      font-weight: 600;
      padding: 4px 2px;
    }
    .avatar-actions a:hover { color: #157aab; }
    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      background: #5b5fcf;
    }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
    }

    .content {
      padding: 1.8rem 2rem;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.2rem;
    }
    .title { font-size: 30px; font-weight: 700; color: #1a1a2e; }
    .date-label {
      font-size: 14px;
      font-weight: 500;
      color: #6b7280;
      border: none;
      background: none;
      cursor: pointer;
      font-family: inherit;
    }
    .date-label:hover { color: #1a8fc1; }
    .hidden-date-input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
      width: 1px;
      height: 1px;
    }

    .table-wrap {
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      overflow: visible;
    }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      text-align: left;
      font-size: 12px;
      color: #9aa3af;
      font-weight: 700;
      letter-spacing: .3px;
      padding: 14px 16px;
      border-bottom: 1px solid #edf1f5;
    }
    .sortable-date {
      cursor: pointer;
      user-select: none;
    }
    tbody td {
      padding: 16px;
      border-bottom: 1px solid #edf1f5;
      font-size: 14px;
      color: #2d3748;
      vertical-align: middle;
    }
    tbody tr:last-child td { border-bottom: none; }

    .status-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 84px;
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 11px;
      font-weight: 700;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: .2px;
    }
    .status-active { background: #ff1b1b; }
    .status-resolved {
      background: #e8f8ee;
      color: #16a34a;
      min-width: 102px;
    }
    .status-icon { margin-right: 6px; font-size: 10px; }
    .row-actions {
      color: #9aa3af;
      font-weight: 700;
      letter-spacing: 1px;
      text-align: center;
    }
    .action-cell {
      position: relative;
      text-align: center;
    }
    .action-btn {
      border: none;
      background: none;
      color: #9aa3af;
      font-weight: 700;
      letter-spacing: 1px;
      cursor: pointer;
      font-family: inherit;
      padding: 2px 4px;
    }
    .action-btn:hover { color: #1a8fc1; }
    .action-menu {
      position: absolute;
      right: 8px;
      top: calc(100% + 6px);
      min-width: 140px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 8px;
      box-shadow: 0 8px 20px rgba(26, 35, 56, 0.14);
      display: none;
      z-index: 120;
      overflow: hidden;
    }
    .action-menu.open-up {
      top: auto;
      bottom: calc(100% + 6px);
    }
    .action-menu.show { display: block; }
    .action-item {
      width: 100%;
      border: none;
      background: #fff;
      text-align: left;
      padding: 9px 12px;
      font-size: 12px;
      color: #4a5568;
      cursor: pointer;
      font-family: inherit;
    }
    .action-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .time-data-modal {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.35);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 150;
    }
    .time-data-modal.show { display: flex; }
    .time-data-card {
      width: min(520px, 92vw);
      background: #fff;
      border-radius: 12px;
      border: 1px solid #e8ecf0;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.2);
      padding: 1rem 1.1rem;
    }
    .time-data-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: .8rem;
    }
    .time-data-title {
      font-size: 16px;
      font-weight: 700;
      color: #1a1a2e;
    }
    .time-data-close {
      border: none;
      background: none;
      font-size: 18px;
      color: #6b7280;
      cursor: pointer;
      line-height: 1;
      padding: 2px 4px;
    }
    .time-data-sub {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: .8rem;
    }
    .time-data-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: .55rem;
    }
    .time-data-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .time-data-item strong {
      display: block;
      font-size: 11px;
      color: #9aa3af;
      margin-bottom: 2px;
      letter-spacing: .25px;
    }
    .time-data-item span {
      font-size: 14px;
      color: #1a1a2e;
      font-weight: 600;
    }
  <%- include('partials/glass-app-theme') %>
  </style>
</head>
