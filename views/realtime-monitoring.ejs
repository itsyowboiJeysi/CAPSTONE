<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Real-Time Monitoring</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    body::-webkit-scrollbar { display: none; }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }
    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }
    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      cursor: pointer;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }
    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }
    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }
    .sidebar-bottom {
      padding: 1rem 0;
      border-top: 1px solid #f0f4f8;
    }

    /* ── MAIN ── */
    .main {
      margin-left: 210px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    /* ── TOPBAR ── */
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      cursor: pointer;
      color: #6b7280;
    }
    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }
    .topbar-action { position: relative; }
    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }
    .topbar-popover.show { display: block; }
    .popover-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .65rem;
    }
    .popover-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .45rem;
    }
    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }
    .popover-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .popover-item span {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.35;
      display: block;
    }
    .avatar-panel { width: 250px; }
    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }
    .avatar-chip {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }
    .avatar-meta strong {
      display: block;
      font-size: 13px;
      color: #1a1a2e;
    }
    .avatar-meta span {
      font-size: 12px;
      color: #6b7280;
    }
    .avatar-actions {
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }
    .avatar-actions a {
      text-decoration: none;
      font-size: 12px;
      color: #1a8fc1;
      font-weight: 600;
      padding: 4px 2px;
    }
    .avatar-actions a:hover { color: #157aab; }
    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
    }
    .badge-blue { background: #1a8fc1; }
    .badge-indigo { background: #5b5fcf; }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
      cursor: pointer;
    }

    /* ── CONTENT ── */
    .content { padding: 1.6rem 2rem; flex: 1; }

    /* Page header row */
    .page-header {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: start;
      margin-bottom: 1.4rem;
    }
    .page-title { font-size: 18px; font-weight: 700; color: #1a1a2e; }
    .page-subtitle { font-size: 13px; color: #9aa3af; margin-top: 2px; }
    .device-name {
      font-size: 28px;
      font-weight: 800;
      color: #1a1a2e;
      text-align: center;
      letter-spacing: 1px;
    }
    .header-right {
      display: flex;
      align-items: flex-start;
      justify-content: flex-end;
      gap: 1.4rem;
    }
    .live-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 14px;
      font-weight: 600;
      color: #1a1a2e;
    }
    .live-dot {
      width: 12px; height: 12px;
      background: #e53e3e;
      border-radius: 50%;
      animation: pulse 1.4s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50%      { opacity: .6; transform: scale(1.2); }
    }
    .header-links { display: flex; gap: 1.2rem; }
    .header-links a {
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      font-weight: 500;
    }
    .header-links a:hover { color: #1a8fc1; }
    .header-links-popover-wrap {
      position: relative;
      display: inline-flex;
    }
    .devices-popover {
      position: absolute;
      top: calc(100% + 8px);
      right: 0;
      width: 250px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 10px;
      box-shadow: 0 12px 24px rgba(26, 35, 56, 0.12);
      padding: .7rem;
      display: none;
      z-index: 70;
    }
    .devices-popover.show { display: block; }
    .device-item-btn {
      width: 100%;
      text-align: left;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }
    .device-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .5rem .6rem;
      background: #f9fbfd;
      margin-bottom: .45rem;
    }
    .device-item:last-child { margin-bottom: 0; }
    .device-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }
    .device-item span {
      display: block;
      font-size: 12px;
      color: #6b7280;
    }
    .device-item-btn:hover .device-item { border-color: #1a8fc1; background: #eef7fc; }

    /* Metric cards */
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.4rem;
    }
    .metric-card {
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      padding: 1rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .metric-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .metric-label { font-size: 12px; color: #9aa3af; margin-bottom: 8px; }
    .metric-value { font-size: 26px; font-weight: 700; color: #1a1a2e; line-height: 1; }
    .metric-unit { font-size: 13px; font-weight: 400; color: #6b7280; margin-left: 2px; }

    /* Chart card */
    .chart-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.2rem 1.4rem;
      margin-bottom: 1.4rem;
    }
    .chart-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .chart-title { font-size: 15px; font-weight: 700; color: #1a1a2e; margin-right: auto; }
    .period-btn {
      background: none;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 4px 12px;
      font-size: 12px;
      color: #6b7280;
      cursor: pointer;
      transition: all .15s;
    }
    .period-btn.active {
      background: #fff;
      border-color: #1a1a2e;
      color: #1a1a2e;
      font-weight: 600;
    }
    .period-btn:hover:not(.active) { border-color: #1a8fc1; color: #1a8fc1; }
    .chart-wrap { position: relative; height: 220px; }

    /* Status cards row */
    .status-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .status-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 12px;
      padding: 1rem 1.4rem 1.2rem;
      position: relative;
      overflow: hidden;
    }
    .status-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }
    .status-label { font-size: 12px; color: #9aa3af; margin-bottom: 8px; }
    .status-value { font-size: 20px; font-weight: 700; color: #1a1a2e; }
  <%- include('partials/glass-app-theme') %>
  </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/monitoring" class="nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Real-Time Monitoring
    </a>
    <a href="/water-quality" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6 9 4 13 4 16a8 8 0 0016 0c0-3-2-7-8-14z"/></svg>
      Water Quality
    </a>
    <a href="/consumption" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Consumption
    </a>
    <a href="/alerts" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Alerts
    </a>
    <a href="/history" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/><rect x="2" y="3" width="4" height="4" rx="1"/><rect x="2" y="10" width="4" height="4" rx="1"/><rect x="2" y="17" width="4" height="4" rx="1"/></svg>
      History/Logs
    </a>
    <a href="/reports" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>
      Reports
    </a>
  </nav>
 
</aside>

<!-- MAIN -->
<div class="main">
  <header class="topbar">
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge badge-indigo">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item">
            <strong>pH Warning</strong>
            <span>Reservoir 2 recorded pH 6.4 at 08:45 AM.</span>
          </li>
          <li class="popover-item">
            <strong>Flow Update</strong>
            <span>Main line flow increased by 12% this hour.</span>
          </li>
          <li class="popover-item">
            <strong>Reminder</strong>
            <span>Monthly compliance report is due today.</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta">
            <strong>Admin User</strong>
            <span>admin@etubig.local</span>
          </div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <div class="content">
    <!-- Page Header -->
    <div class="page-header">
      <div>
        <div class="page-title">Real-Time Monitoring</div>
        <div class="page-subtitle">Live Sensor Tracking</div>
      </div>
      <div class="device-name" id="deviceName">ESP DEVICE NAME</div>
      <div class="header-right">
        <div class="live-badge">
          <span class="live-dot"></span> LIVE
        </div>
        <div class="header-links">
          <div class="header-links-popover-wrap" data-device-wrap>
            <a href="#" id="devicesLink">Devices</a>
            <div class="devices-popover" id="devicesPopover"></div>
          </div>
          <a href="#">Map</a>
        </div>
      </div>
    </div>

    <!-- Metrics -->
    <div class="metric-grid">
      <div class="metric-card">
        <div class="metric-label">pH Level</div>
        <div class="metric-value" data-metric-value="ph">7.2<span class="metric-unit">pH</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Turbidity</div>
        <div class="metric-value" data-metric-value="turbidity">2.1<span class="metric-unit">NTU</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Temperature</div>
        <div class="metric-value" data-metric-value="temperature">23<span class="metric-unit">°C</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Flow Rate</div>
        <div class="metric-value" data-metric-value="flow">50<span class="metric-unit">L/min</span></div>
      </div>
    </div>

    <!-- Chart -->
    <div class="chart-card">
      <div class="chart-header">
        <span class="chart-title">Water Consumption Reports</span>
        <button class="period-btn active" onclick="switchPeriod(this,'30m')">30 mins</button>
        <button class="period-btn" onclick="switchPeriod(this,'1h')">1 hour</button>
        <button class="period-btn" onclick="switchPeriod(this,'3h')">3 hours</button>
        <button class="period-btn" onclick="switchPeriod(this,'8h')">8 hrs</button>
      </div>
      <div class="chart-wrap">
        <canvas id="liveChart"></canvas>
      </div>
    </div>

    <!-- Status cards -->
    <div class="status-grid">
      <div class="status-card">
        <div class="status-label">MQTT Connection</div>
        <div class="status-value">Connected</div>
      </div>
      <div class="status-card">
        <div class="status-label">Status</div>
        <div class="status-value">Normal</div>
      </div>
      <div class="status-card">
        <div class="status-label">Last Update</div>
        <div class="status-value" id="lastUpdate">--</div>
      </div>
    </div>
  </div>
</div>

<script>
  // Live clock
  function updateClock() {
    const now = new Date();
    document.getElementById('lastUpdate').textContent =
      now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }
  updateClock();
  setInterval(updateClock, 1000);

  // Chart data
  const months = ['Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan'];
  function makePoints(base, count, spread) {
    return Array.from({length: count}, (_, i) => base + Math.sin(i * 0.4) * spread + Math.random() * (spread * 0.5));
  }

  const periodData = {
    '30m': { labels: Array.from({length:30},(_,i)=>i%5===0?`${i}m`:''), data: [makePoints(300,30,60), makePoints(180,30,40)] },
    '1h':  { labels: Array.from({length:12},(_,i)=>`${i*5}m`),           data: [makePoints(310,12,65), makePoints(185,12,42)] },
    '3h':  { labels: Array.from({length:18},(_,i)=>`${i*10}m`),          data: [makePoints(320,18,70), makePoints(190,18,45)] },
    '8h':  { labels: months,                                               data: [makePoints(340,12,80), makePoints(200,12,50)] },
  };
  const deviceProfiles = [
    {
      name: 'ESP-32 Main Tank',
      topic: 'etubig/main-tank/status',
      metrics: { ph: 7.2, turbidity: 2.1, temperature: 23, flow: 50 },
      periodData
    },
    {
      name: 'ESP-32 Zone A',
      topic: 'etubig/zone-a/status',
      metrics: { ph: 6.7, turbidity: 3.4, temperature: 26, flow: 58 },
      periodData: {
        '30m': { labels: Array.from({length:30},(_,i)=>i%5===0?`${i}m`:''), data: [makePoints(280,30,55), makePoints(220,30,50)] },
        '1h':  { labels: Array.from({length:12},(_,i)=>`${i*5}m`),           data: [makePoints(290,12,58), makePoints(225,12,52)] },
        '3h':  { labels: Array.from({length:18},(_,i)=>`${i*10}m`),          data: [makePoints(300,18,65), makePoints(230,18,56)] },
        '8h':  { labels: months,                                               data: [makePoints(315,12,70), makePoints(240,12,58)] },
      }
    },
    {
      name: 'ESP-8266 Pump House',
      topic: 'etubig/pump-house/status',
      metrics: { ph: 7.8, turbidity: 1.3, temperature: 22, flow: 64 },
      periodData: {
        '30m': { labels: Array.from({length:30},(_,i)=>i%5===0?`${i}m`:''), data: [makePoints(340,30,50), makePoints(150,30,34)] },
        '1h':  { labels: Array.from({length:12},(_,i)=>`${i*5}m`),           data: [makePoints(350,12,54), makePoints(155,12,36)] },
        '3h':  { labels: Array.from({length:18},(_,i)=>`${i*10}m`),          data: [makePoints(360,18,58), makePoints(160,18,40)] },
        '8h':  { labels: months,                                               data: [makePoints(375,12,62), makePoints(165,12,42)] },
      }
    },
  ];

  const colors = [
    { line: '#2d3ac8', fill: 'rgba(45,58,200,0.10)' },
    { line: '#a5b4fc', fill: 'rgba(165,180,252,0.07)' },
  ];

  function makeDatasets(d) {
    return d.data.map((pts, i) => ({
      data: pts,
      borderColor: colors[i].line,
      backgroundColor: colors[i].fill,
      fill: true,
      tension: 0.5,
      borderWidth: i === 0 ? 2.5 : 1.5,
      pointRadius: 0,
    }));
  }

  const ctx = document.getElementById('liveChart').getContext('2d');
  const deviceNameEl = document.getElementById('deviceName');
  let activeDevice = deviceProfiles[0];
  let currentPeriod = '30m';
  const liveChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: activeDevice.periodData['30m'].labels,
      datasets: makeDatasets(activeDevice.periodData['30m']),
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 400 },
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9aa3af', font: { size: 11 } } },
        y: {
          display: true,
          beginAtZero: true,
          grid: { color: '#eef2f7' },
          ticks: {
            color: '#9aa3af',
            font: { size: 11 },
            precision: 0
          }
        },
      },
    }
  });

  function switchPeriod(btn, key) {
    btn.closest('.chart-header').querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentPeriod = key;
    const d = activeDevice.periodData[key];
    liveChart.data.labels = d.labels;
    liveChart.data.datasets = makeDatasets(d);
    liveChart.update();
  }

  function setMetricValue(key, value, unit) {
    const el = document.querySelector(`[data-metric-value="${key}"]`);
    if (!el || !Number.isFinite(value)) return;
    const rounded = key === 'temperature' || key === 'flow' ? Math.round(value) : value.toFixed(1);
    el.innerHTML = `${rounded}<span class="metric-unit">${unit}</span>`;
  }

  function applyDeviceProfile(device) {
    activeDevice = device;
    if (deviceNameEl) deviceNameEl.textContent = device.name;
    setMetricValue('ph', device.metrics.ph, 'pH');
    setMetricValue('turbidity', device.metrics.turbidity, 'NTU');
    setMetricValue('temperature', device.metrics.temperature, '°C');
    setMetricValue('flow', device.metrics.flow, 'L/min');
    const selected = activeDevice.periodData[currentPeriod] || activeDevice.periodData['30m'];
    liveChart.data.labels = selected.labels;
    liveChart.data.datasets = makeDatasets(selected);
    liveChart.update();
  }

  // Simulate live data update every 3s
  setInterval(() => {
    liveChart.data.datasets.forEach(ds => {
      ds.data.shift();
      ds.data.push(ds.data[ds.data.length - 1] + (Math.random() - 0.48) * 20);
    });
    liveChart.update('none');
  }, 3000);

  // Topbar popovers (notification + admin profile)
  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');
  const devicesLink = document.getElementById('devicesLink');
  const devicesPopover = document.getElementById('devicesPopover');
  const activeEspDevices = deviceProfiles;

  if (devicesPopover) {
    devicesPopover.innerHTML = activeEspDevices
      .map((device, index) => `<button type="button" class="device-item-btn" data-device-index="${index}"><div class="device-item"><strong>${device.name}</strong><span>MQTT: ${device.topic}</span></div></button>`)
      .join('');
  }

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  if (devicesLink && devicesPopover) {
    devicesLink.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      const isOpen = devicesPopover.classList.contains('show');
      closeAllPopovers();
      devicesPopover.classList.toggle('show', !isOpen);
    });

    devicesPopover.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-device-index]');
      if (!btn) return;
      const idx = Number(btn.getAttribute('data-device-index'));
      if (Number.isNaN(idx) || !activeEspDevices[idx]) return;
      applyDeviceProfile(activeEspDevices[idx]);
      devicesPopover.classList.remove('show');
    });
  }

  applyDeviceProfile(activeDevice);

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) {
      closeAllPopovers();
    }
    if (!event.target.closest('[data-device-wrap]')) {
      devicesPopover && devicesPopover.classList.remove('show');
    }
  });
</script>
</body>
</html>
