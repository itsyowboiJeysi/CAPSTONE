<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>E-Tubig | Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html, body {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    html::-webkit-scrollbar,
    body::-webkit-scrollbar,
    .main::-webkit-scrollbar,
    .content::-webkit-scrollbar { display: none; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      display: flex;
      min-height: 100vh;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: 210px;
      min-height: 100vh;
      background: #fff;
      border-right: 1px solid #e8ecf0;
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0; left: 0; bottom: 0;
      z-index: 100;
      overflow-y: auto;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }

    .sidebar-brand {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 1.3rem 1.4rem;
      color: #1a8fc1;
      font-weight: 700;
      font-size: 16px;
      border-bottom: 1px solid #f0f4f8;
    }

    .sidebar-brand svg { flex-shrink: 0; }

    .sidebar-nav {
      flex: 1;
      padding: 1rem 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 1.4rem;
      font-size: 14px;
      color: #6b7280;
      text-decoration: none;
      border-radius: 0;
      cursor: pointer;
      transition: background .15s, color .15s;
    }

    .nav-item:hover { background: #f0f7fb; color: #1a8fc1; }

    .nav-item.active {
      background: #e8f4fb;
      color: #1a8fc1;
      font-weight: 600;
      border-right: 3px solid #1a8fc1;
    }

    .nav-item svg { width: 17px; height: 17px; flex-shrink: 0; }

    .sidebar-bottom {
      padding: 1rem 0;
      border-top: 1px solid #f0f4f8;
    }

    /* ── MAIN ── */
    .main {
      margin-left: 210px;
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* ── TOPBAR ── */
    .topbar {
      background: #fff;
      border-bottom: 1px solid #e8ecf0;
      padding: .75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 1rem;
      position: sticky;
      top: 0;
      z-index: 50;
    }

    .topbar-icon {
      position: relative;
      width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 50%;
      background: #f4f6f9;
      cursor: pointer;
      color: #6b7280;
    }

    .topbar-icon:hover { background: #e8f4fb; color: #1a8fc1; }

    .topbar-action {
      position: relative;
    }

    .topbar-popover {
      position: absolute;
      top: calc(100% + 10px);
      right: 0;
      width: 290px;
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      box-shadow: 0 14px 30px rgba(26, 35, 56, 0.12);
      padding: .8rem;
      display: none;
      z-index: 80;
    }

    .topbar-popover.show { display: block; }

    .popover-title {
      font-size: 13px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: .65rem;
    }

    .popover-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: .45rem;
    }

    .popover-item {
      border: 1px solid #eef2f7;
      border-radius: 8px;
      padding: .55rem .65rem;
      background: #f9fbfd;
    }

    .popover-item strong {
      display: block;
      font-size: 12px;
      color: #1a1a2e;
      margin-bottom: 2px;
    }

    .popover-item span {
      font-size: 12px;
      color: #6b7280;
      line-height: 1.35;
      display: block;
    }

    .avatar-panel {
      width: 250px;
    }

    .avatar-head {
      display: flex;
      align-items: center;
      gap: .65rem;
      margin-bottom: .65rem;
      padding-bottom: .65rem;
      border-bottom: 1px solid #eef2f7;
    }

    .avatar-chip {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: #1a8fc1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 700;
      font-size: 14px;
    }

    .avatar-meta strong {
      display: block;
      font-size: 13px;
      color: #1a1a2e;
    }

    .avatar-meta span {
      font-size: 12px;
      color: #6b7280;
    }

    .avatar-actions {
      display: flex;
      flex-direction: column;
      gap: .35rem;
    }

    .avatar-actions a {
      text-decoration: none;
      font-size: 12px;
      color: #1a8fc1;
      font-weight: 600;
      padding: 4px 2px;
    }

    .avatar-actions a:hover { color: #157aab; }

    .badge {
      position: absolute;
      top: -2px; right: -2px;
      width: 17px; height: 17px;
      border-radius: 50%;
      font-size: 10px;
      font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      color: #fff;
    }

    .badge-blue { background: #1a8fc1; }
    .badge-indigo { background: #5b5fcf; }

    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #cbd5e0;
      overflow: hidden;
      cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; color: #fff; font-size: 14px;
    }

    /* ── CONTENT ── */
    .content {
      padding: 1.8rem 2rem;
      flex: 1;
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    .greeting {
      font-size: 17px;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 1.4rem;
    }

    .greeting span {
      font-weight: 400;
      color: #6b7280;
      font-size: 15px;
    }

    /* ── METRIC CARDS ── */
    .metric-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .metric-card {
      background: #fff;
      border: 1px solid #e8ecf0;
      border-radius: 12px;
      padding: 1rem 1.2rem 1rem;
      position: relative;
      overflow: hidden;
    }

    .metric-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
    }

    .metric-label {
      font-size: 12px;
      color: #9aa3af;
      margin-bottom: 8px;
      letter-spacing: .3px;
    }

    .metric-value {
      font-size: 26px;
      font-weight: 700;
      color: #1a1a2e;
      line-height: 1;
    }

    .metric-unit {
      font-size: 13px;
      font-weight: 400;
      color: #6b7280;
      margin-left: 2px;
    }

    /* ── BOTTOM ROW ── */
    .charts-row {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 1rem;
      margin-bottom: 1.4rem;
    }

    .chart-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.2rem 1.4rem;
    }

    .chart-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .chart-title {
      font-size: 15px;
      font-weight: 700;
      color: #1a1a2e;
      margin-right: auto;
    }

    .period-btn {
      background: none;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      padding: 4px 12px;
      font-size: 12px;
      color: #6b7280;
      cursor: pointer;
      transition: all .15s;
    }

    .period-btn.active {
      background: #fff;
      border-color: #1a1a2e;
      color: #1a1a2e;
      font-weight: 600;
    }

    .period-btn:hover:not(.active) { border-color: #1a8fc1; color: #1a8fc1; }

    .chart-wrap { position: relative; height: 200px; }

    /* Potability Card */
    .potability-card {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.4rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      text-align: center;
    }

    .potability-title {
      font-size: 15px;
      font-weight: 700;
      color: #1a1a2e;
    }

    .potability-icon {
      width: 64px; height: 64px;
      display: flex; align-items: center; justify-content: center;
    }

    .potability-status {
      font-size: 18px;
      font-weight: 700;
      color: #1a1a2e;
    }

    .potability-bar {
      width: 80%;
      height: 3px;
      background: linear-gradient(90deg, #1a8fc1, #29b6d1);
      border-radius: 4px;
    }

    /* Full-width chart */
    .chart-card-full {
      background: #fff;
      border: 1.5px solid #c8e6f5;
      border-radius: 14px;
      padding: 1.2rem 1.4rem;
    }

    .chart-wrap-full { position: relative; height: 200px; }
  </style>
</head>
<body>

<!-- ── SIDEBAR ── -->
<aside class="sidebar">
  <div class="sidebar-brand">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
      <path d="M12 2L4 9v11h5v-6h6v6h5V9z" fill="#1a8fc1"/>
      <polygon points="12,2 20,9 4,9" fill="#29b6d1"/>
    </svg>
    E-Tubig
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item active">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Dashboard
    </a>
    <a href="/monitoring" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Real-Time Monitoring
    </a>
    <a href="/water-quality" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6 9 4 13 4 16a8 8 0 0016 0c0-3-2-7-8-14z"/></svg>
      Water Quality
    </a>
    <a href="/consumption" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Consumption
    </a>
    <a href="/alerts" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Alerts
    </a>
    <a href="/history" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/><rect x="2" y="3" width="4" height="4" rx="1"/><rect x="2" y="10" width="4" height="4" rx="1"/><rect x="2" y="17" width="4" height="4" rx="1"/></svg>
      History/Logs
    </a>
    <a href="/reports" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="11" x2="15" y2="11"/><line x1="9" y1="15" x2="13" y2="15"/></svg>
      Reports
    </a>
  </nav>

 
</aside>

<!-- ── MAIN ── -->
<div class="main">

  <!-- Topbar -->
  <header class="topbar">
    <div class="topbar-action" data-popover-wrap>
      <div class="topbar-icon" data-popover-toggle="alerts">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        <span class="badge badge-indigo">6</span>
      </div>
      <div class="topbar-popover" data-popover-id="alerts">
        <div class="popover-title">Notifications</div>
        <ul class="popover-list">
          <li class="popover-item">
            <strong>pH Warning</strong>
            <span>Reservoir 2 recorded pH 6.4 at 08:45 AM.</span>
          </li>
          <li class="popover-item">
            <strong>Flow Update</strong>
            <span>Main line flow increased by 12% this hour.</span>
          </li>
          <li class="popover-item">
            <strong>Reminder</strong>
            <span>Monthly compliance report is due today.</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="topbar-action" data-popover-wrap>
      <div class="avatar" data-popover-toggle="admin">A</div>
      <div class="topbar-popover avatar-panel" data-popover-id="admin">
        <div class="avatar-head">
          <div class="avatar-chip">A</div>
          <div class="avatar-meta">
            <strong>Admin User</strong>
            <span>admin@etubig.local</span>
          </div>
        </div>
        <div class="avatar-actions">
          <a href="/settings">Account Settings</a>
          <a href="/reports">View Reports</a>
          <a href="/logout">Sign Out</a>
        </div>
      </div>
    </div>
  </header>

  <!-- Content -->
  <div class="content">

    <p class="greeting">
      Hey Admin &nbsp;–&nbsp; <span>here's what's happening with the water today</span>
    </p>

    <!-- Metric Cards -->
    <div class="metric-grid">
      <div class="metric-card">
        <div class="metric-label">pH Level</div>
        <div class="metric-value">7.2<span class="metric-unit">pH</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Turbidity</div>
        <div class="metric-value">2.1<span class="metric-unit">NTU</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Temperature</div>
        <div class="metric-value">23<span class="metric-unit">°C</span></div>
      </div>
      <div class="metric-card">
        <div class="metric-label">Flow Rate</div>
        <div class="metric-value">50<span class="metric-unit">L/min</span></div>
      </div>
    </div>

    <!-- Water Quality Charts + Potability -->
    <div class="charts-row">
      <div class="chart-card">
        <div class="chart-header">
          <span class="chart-title">Water Quality Reports</span>
          <button class="period-btn active" onclick="switchPeriod(this,'quality','12m')">12 Months</button>
          <button class="period-btn" onclick="switchPeriod(this,'quality','6m')">6 Months</button>
          <button class="period-btn" onclick="switchPeriod(this,'quality','30d')">30 Days</button>
          <button class="period-btn" onclick="switchPeriod(this,'quality','7d')">7 Days</button>
        </div>
        <div class="chart-wrap">
          <canvas id="qualityChart"></canvas>
        </div>
      </div>

      <div class="potability-card">
        <div class="potability-title">Potability Status</div>
        <div class="potability-icon">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
            <rect x="4" y="4" width="56" height="56" rx="8" fill="#e8f4fb" stroke="#1a8fc1" stroke-width="3"/>
            <polyline points="18,34 28,44 48,22" stroke="#1a8fc1" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="potability-status">Safe to Use</div>
        <div class="potability-bar"></div>
      </div>
    </div>

    <!-- Water Consumption Chart -->
    <div class="chart-card-full">
      <div class="chart-header">
        <span class="chart-title">Water Consumption Reports</span>
        <button class="period-btn active" onclick="switchPeriod(this,'consumption','12m')">12 Months</button>
        <button class="period-btn" onclick="switchPeriod(this,'consumption','6m')">6 Months</button>
        <button class="period-btn" onclick="switchPeriod(this,'consumption','30d')">30 Days</button>
        <button class="period-btn" onclick="switchPeriod(this,'consumption','7d')">7 Days</button>
      </div>
      <div class="chart-wrap-full">
        <canvas id="consumptionChart"></canvas>
      </div>
    </div>

  </div>
</div>

<script>
  // ── Chart data sets ──
  const months12 = ['Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan'];
  const months6  = ['Aug','Sep','Oct','Nov','Dec','Jan'];
  const days30   = Array.from({length:30},(_,i)=>`D${i+1}`);
  const days7    = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  const qualityData = {
    '12m': { labels: months12,
      datasets: [
        [280,320,295,360,410,390,430,480,520,490,560,610],
        [180,200,190,230,260,250,280,320,350,330,370,410],
        [100,120,110,130,150,145,160,180,200,185,210,230],
      ]
    },
    '6m':  { labels: months6,
      datasets: [
        [430,480,520,490,560,610],
        [280,320,350,330,370,410],
        [160,180,200,185,210,230],
      ]
    },
    '30d': { labels: days30,
      datasets: [
        Array.from({length:30},()=>Math.floor(350+Math.random()*200)),
        Array.from({length:30},()=>Math.floor(200+Math.random()*100)),
        Array.from({length:30},()=>Math.floor(100+Math.random()*60)),
      ]
    },
    '7d':  { labels: days7,
      datasets: [
        [490,510,525,480,560,545,610],
        [330,345,360,320,380,365,410],
        [185,195,205,175,215,200,230],
      ]
    },
  };

  const consumptionData = {
    '12m': { labels: months12,
      datasets: [
        [150,200,180,250,300,280,310,360,400,380,430,470],
        [80,100,90,120,140,130,150,175,190,180,205,225],
        [40,50,45,60,70,65,75,88,96,90,103,113],
      ]
    },
    '6m':  { labels: months6,
      datasets: [
        [310,360,400,380,430,470],
        [150,175,190,180,205,225],
        [75,88,96,90,103,113],
      ]
    },
    '30d': { labels: days30,
      datasets: [
        Array.from({length:30},()=>Math.floor(220+Math.random()*180)),
        Array.from({length:30},()=>Math.floor(110+Math.random()*90)),
        Array.from({length:30},()=>Math.floor(50+Math.random()*50)),
      ]
    },
    '7d':  { labels: days7,
      datasets: [
        [380,400,415,370,445,430,470],
        [180,190,200,165,210,200,225],
        [90,96,102,82,107,100,113],
      ]
    },
  };

  function makeDatasets(data) {
    const colors = [
      { line: '#2d3ac8', fill: 'rgba(45,58,200,0.12)' },
      { line: '#6b8cff', fill: 'rgba(107,140,255,0.10)' },
      { line: '#a5b4fc', fill: 'rgba(165,180,252,0.08)' },
    ];
    return data.datasets.map((d, i) => ({
      data: d,
      borderColor: colors[i].line,
      backgroundColor: colors[i].fill,
      fill: true,
      tension: 0.5,
      borderWidth: i === 0 ? 2.5 : 1.5,
      pointRadius: 0,
    }));
  }

  const chartDefaults = {
    type: 'line',
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { mode: 'index', intersect: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9aa3af', font: { size: 11 } } },
        y: {
          display: true,
          beginAtZero: true,
          grid: { color: '#eef2f7' },
          ticks: {
            color: '#9aa3af',
            font: { size: 11 },
            precision: 0
          }
        },
      },
      interaction: { mode: 'nearest', axis: 'x', intersect: false },
    }
  };

  // Init charts
  const qCtx = document.getElementById('qualityChart').getContext('2d');
  const cCtx = document.getElementById('consumptionChart').getContext('2d');

  const qualityChart = new Chart(qCtx, {
    ...chartDefaults,
    data: { labels: qualityData['12m'].labels, datasets: makeDatasets(qualityData['12m']) }
  });

  const consumptionChart = new Chart(cCtx, {
    ...chartDefaults,
    data: { labels: consumptionData['12m'].labels, datasets: makeDatasets(consumptionData['12m']) }
  });

  const charts = { quality: qualityChart, consumption: consumptionChart };
  const dataMap = { quality: qualityData, consumption: consumptionData };

  function switchPeriod(btn, chartKey, period) {
    // Update button styles in same group
    btn.closest('.chart-header').querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    const chart = charts[chartKey];
    const d = dataMap[chartKey][period];
    chart.data.labels = d.labels;
    chart.data.datasets = makeDatasets(d);
    chart.update();
  }

  // Topbar popovers (notification + admin profile)
  const popovers = document.querySelectorAll('[data-popover-id]');
  const toggles = document.querySelectorAll('[data-popover-toggle]');

  function closeAllPopovers() {
    popovers.forEach((popover) => popover.classList.remove('show'));
  }

  toggles.forEach((toggle) => {
    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const targetId = toggle.getAttribute('data-popover-toggle');
      const targetPopover = document.querySelector(`[data-popover-id="${targetId}"]`);
      const isOpen = targetPopover && targetPopover.classList.contains('show');
      closeAllPopovers();
      if (targetPopover && !isOpen) targetPopover.classList.add('show');
    });
  });

  document.addEventListener('click', (event) => {
    if (!event.target.closest('[data-popover-wrap]')) {
      closeAllPopovers();
    }
  });
</script>

</body>
</html>
